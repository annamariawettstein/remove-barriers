---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lattice — Mapping Power, Money, and Influence',
  description = 'Lattice connects public records, lobbying disclosures, donation filings, and corporate registries to trace the relationships between politicians, companies, and money.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&family=Newsreader:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      .font-sans { font-family: 'Inter', 'Satoshi', sans-serif; }
      .font-serif { font-family: 'Newsreader', 'Georgia', serif; }
    </style>
  </head>
  <body class="bg-retro-bg text-retro-ink selection:bg-retro-green/30 selection:text-retro-green antialiased overflow-x-hidden font-sans">
    <slot />
  </body>
</html>
