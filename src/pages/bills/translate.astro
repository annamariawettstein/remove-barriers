---
export const prerender = true;
import LightLayout from '../../layouts/LightLayout.astro';
---

<LightLayout title="Translated bill — Lattice">
  <main class="relative z-10 max-w-[1440px] mx-auto px-6 lg:px-8 xl:px-10 py-12 bg-retro-bg">

    <!-- Breadcrumb -->
    <div class="mb-8 text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] flex items-center gap-3">
      <a href="/" class="hover:text-retro-ink transition">Lattice</a>
      <span class="text-retro-ink/20">/</span>
      <a href="/bills" class="hover:text-retro-ink transition">Policy Translator</a>
      <span class="text-retro-ink/20">/</span>
      <span class="text-retro-ink" id="bill-breadcrumb">Translated</span>
    </div>

    <!-- Translation banner -->
    <div class="mb-8 flex items-center gap-3 text-[10px] font-mono uppercase tracking-[0.18em] text-retro-green">
      <span class="w-1.5 h-1.5 rounded-full bg-retro-green"></span>
      <span>Policy Translator · AI-translated by Kimi K2.5 · cite legislation.gov.uk for legal use</span>
    </div>

    <div id="bill-content"></div>
    <div id="bill-history"></div>

    <div id="bill-missing" class="hidden text-center py-24">
      <h1 class="text-2xl font-semibold text-retro-ink mb-3">No translated bill found</h1>
      <p class="text-sm text-retro-slate mb-6">No saved bill summary was found in this browser yet. Run a new translation from the bills index.</p>
      <a href="/bills" class="inline-block bg-retro-green text-white px-6 py-3 text-sm font-medium hover:bg-retro-ledger transition-colors rounded-sm">← Back to Bills</a>
    </div>
  </main>

  <script is:inline>
    (function () {
      const container = document.getElementById('bill-content');
      const historyContainer = document.getElementById('bill-history');
      const missing = document.getElementById('bill-missing');
      const SESSION_CURRENT_KEY = 'lattice.translatedBill';
      const BILL_HISTORY_KEY = 'lattice.billHistory.v1';
      const ACTIVE_BILL_KEY = 'lattice.translatedBill.activeId';
      const MAX_BILL_HISTORY = 12;

      const esc = (s) => String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
      const magnitudeDots = (n) => '●'.repeat(n) + '○'.repeat(Math.max(0, 5 - n));
      const effectColor = (e) => ({ enhance:'text-retro-green', restrict:'text-amber-700', mixed:'text-retro-slate' }[e] || 'text-retro-slate');
      const effectLabel = (e) => ({ enhance:'Strengthens', restrict:'Restricts', mixed:'Mixed effect' }[e] || e);
      const arr = (x) => Array.isArray(x) ? x : [];
      const billId = (bill) => {
        const slug = (bill && bill.slug ? String(bill.slug) : '').trim();
        if (slug) return `slug:${slug}`;
        const title = (bill && bill.shortTitle ? String(bill.shortTitle) : 'translated').trim().toLowerCase();
        return `summary:${title.replace(/[^a-z0-9]+/g, '-')}`;
      };
      const loadBillHistory = () => {
        try { return JSON.parse(localStorage.getItem(BILL_HISTORY_KEY) || '[]'); }
        catch { return []; }
      };
      const saveBillHistory = (bill) => {
        const history = loadBillHistory().filter(entry => entry.id !== billId(bill));
        const entry = { id: billId(bill), savedAt: Date.now(), bill };
        history.unshift(entry);
        localStorage.setItem(BILL_HISTORY_KEY, JSON.stringify(history.slice(0, MAX_BILL_HISTORY)));
        localStorage.setItem(ACTIVE_BILL_KEY, entry.id);
        return entry.id;
      };
      const formatSavedAt = (savedAt) => {
        try {
          return new Intl.DateTimeFormat('en-GB', {
            day: 'numeric',
            month: 'short',
            hour: '2-digit',
            minute: '2-digit'
          }).format(savedAt);
        } catch {
          return '';
        }
      };

      const ICON_PATHS = {
        summary:    `<rect x="5" y="3" width="14" height="18" rx="0.5"/><path d="M9 3v2h6V3"/><line x1="8" y1="9" x2="16" y2="9"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/>`,
        stats:      `<line x1="3" y1="21" x2="21" y2="21"/><rect x="5" y="13" width="3" height="8"/><rect x="10.5" y="9" width="3" height="12"/><rect x="16" y="5" width="3" height="16"/>`,
        target:     `<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/>`,
        search:     `<circle cx="11" cy="11" r="6"/><line x1="15.5" y1="15.5" x2="20" y2="20"/>`,
        people:     `<circle cx="9" cy="9" r="3"/><circle cx="17" cy="10.5" r="2.3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><path d="M14.5 20c0-2.4 1.9-4.3 4.3-4.3"/>`,
        scales:     `<path d="M12 4v17"/><line x1="6" y1="21" x2="18" y2="21"/><path d="M6 8h12l-3 7H9z"/><line x1="6" y1="8" x2="18" y2="8"/>`,
        book:       `<path d="M12 5v15"/><path d="M3 5c3 0 6 .5 9 2v15c-3-1.5-6-2-9-2z"/><path d="M21 5c-3 0-6 .5-9 2v15c3-1.5 6-2 9-2z"/>`,
        calendar:   `<rect x="3.5" y="5.5" width="17" height="15" rx="0.5"/><line x1="3.5" y1="10" x2="20.5" y2="10"/><line x1="8" y1="3" x2="8" y2="7"/><line x1="16" y1="3" x2="16" y2="7"/>`,
        check:      `<circle cx="12" cy="12" r="9"/><path d="M8 12.5l3 3 5-6"/>`,
        pound:      `<circle cx="12" cy="12" r="9"/><path d="M9 17h7"/><path d="M15 11.5h-6"/><path d="M9.5 17c2-1 2-3.5 2-5 0-2.5 1-4 3.5-4 1.2 0 2 .5 2.5 1"/>`,
        speech:     `<path d="M4 5h14a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H10l-4 4v-4H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/>`,
        warning:    `<path d="M12 3l10 18H2z"/><line x1="12" y1="10" x2="12" y2="15"/><circle cx="12" cy="18" r="0.8" fill="currentColor"/>`,
        library:    `<rect x="3.5" y="4" width="3" height="16"/><rect x="7.5" y="4" width="3" height="16"/><rect x="13" y="6" width="3" height="14" transform="rotate(-12 14.5 13)"/><line x1="2" y1="20.5" x2="20" y2="20.5"/>`,
        house:      `<path d="M4 11l8-7 8 7"/><path d="M6 10v10h12V10"/><rect x="10" y="14" width="4" height="6"/>`,
        briefcase:  `<rect x="3" y="7" width="18" height="13" rx="0.5"/><path d="M8 7V5a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2"/><line x1="3" y1="13" x2="21" y2="13"/>`,
        leaf:       `<path d="M5 19c0-8 6-14 14-14 0 8-6 14-14 14z"/><path d="M5 19c4-4 7-7 14-14"/>`,
        shield:     `<path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6z"/><path d="M9 12l2 2 4-4"/>`,
        cabinet:    `<rect x="4" y="4" width="16" height="16" rx="0.5"/><line x1="4" y1="10" x2="20" y2="10"/><line x1="4" y1="14.5" x2="20" y2="14.5"/><circle cx="12" cy="7" r="0.6" fill="currentColor"/><circle cx="12" cy="12.25" r="0.6" fill="currentColor"/><circle cx="12" cy="17.25" r="0.6" fill="currentColor"/>`,
        graph:      `<circle cx="6" cy="6" r="2.2"/><circle cx="18" cy="6" r="2.2"/><circle cx="12" cy="13" r="2.2"/><circle cx="6" cy="20" r="2.2"/><circle cx="18" cy="20" r="2.2"/><line x1="7.5" y1="7.5" x2="10.5" y2="11.5"/><line x1="13.5" y1="11.5" x2="16.5" y2="7.5"/><line x1="7.5" y1="18.5" x2="10.5" y2="14.5"/><line x1="13.5" y1="14.5" x2="16.5" y2="18.5"/>`,
      };
      const iconSvg = (name, sizeClass = 'w-3.5 h-3.5', colorClass = 'text-retro-green') => {
        const p = ICON_PATHS[name];
        if (!p) return '';
        return `<svg class="${sizeClass} ${colorClass} inline-block flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">${p}</svg>`;
      };

      function section(iconName, title, body, extraClasses = '') {
        if (!body) return '';
        return `
          <section class="mb-14 ${extraClasses}">
            <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-4 flex items-center gap-2">${iconSvg(iconName)}${esc(title)}</h2>
            ${body}
          </section>
        `;
      }

      function renderHistory(activeId) {
        const history = loadBillHistory();
        if (!history.length) {
          historyContainer.innerHTML = '';
          return;
        }
        historyContainer.innerHTML = `
          <section class="mt-16 pt-6 border-t border-retro-ink/15">
            <div class="flex flex-wrap items-center justify-between gap-3 mb-6 text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em]">
              <span>Previous summaries</span>
              <span>${String(history.length).padStart(2, '0')} saved in this browser</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              ${history.map(entry => `
                <button
                  type="button"
                  data-bill-history-id="${esc(entry.id)}"
                  class="text-left bg-white border rounded-md p-5 transition hover:border-retro-green ${entry.id === activeId ? 'border-retro-green shadow-[3px_3px_0px_rgba(15,61,46,0.14)]' : 'border-retro-border'}"
                >
                  <div class="flex items-start justify-between gap-4 mb-2">
                    <div>
                      <h3 class="text-lg font-semibold text-retro-ink tracking-tight">${esc(entry.bill.shortTitle || 'Translated bill')}</h3>
                      <p class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mt-1">${esc(entry.bill.status || 'Saved summary')}</p>
                    </div>
                    <span class="text-[10px] font-mono text-retro-slate uppercase tracking-widest">${esc(formatSavedAt(entry.savedAt))}</span>
                  </div>
                  <p class="text-sm text-retro-slate leading-relaxed">${esc(entry.bill.plainEnglishBottomLine || entry.bill.summary || 'Saved bill summary')}</p>
                </button>
              `).join('')}
            </div>
          </section>
        `;
      }

      function renderBill(bill) {
        document.getElementById('bill-breadcrumb').textContent = bill.shortTitle || 'Translated';
        document.title = (bill.shortTitle || 'Translated bill') + ' — Lattice';

        const headerBlock = `
        <div class="border-t border-retro-ink/15 pt-3 flex items-center justify-between text-[9px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-10">
          <div class="flex items-center gap-5">
            <span>BILL · ${esc((bill.slug || '').toUpperCase())}</span>
            ${bill.territorialExtent && bill.territorialExtent.length ? `<span class="hidden md:inline">${esc(arr(bill.territorialExtent).join(' · '))}</span>` : ''}
          </div>
          ${bill.status ? `<div class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-retro-green"></span><span>${esc(bill.status)}</span></div>` : ''}
        </div>
        <header class="mb-14">
          ${bill.icon && ICON_PATHS[bill.icon] ? `<div class="mb-5"><svg class="w-12 h-12 text-retro-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">${ICON_PATHS[bill.icon]}</svg></div>` : ''}
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold text-retro-ink tracking-tight leading-[1.05] mb-4">${esc(bill.shortTitle || 'Untitled bill')}</h1>
          ${bill.fullTitle || bill.sponsoringDept ? `<p class="text-base text-retro-slate font-mono">${esc(bill.fullTitle || '')}${bill.sponsoringDept ? ' · ' + esc(bill.sponsoringDept) : ''}</p>` : ''}
          ${bill.introducedDate || bill.stageDetail ? `<p class="mt-1 text-base text-retro-slate font-mono">${bill.introducedDate ? 'Introduced ' + esc(bill.introducedDate) : ''}${bill.introducedDate && bill.stageDetail ? ' · ' : ''}${esc(bill.stageDetail || '')}</p>` : ''}
        </header>
      `;

      const plainEnglish = (bill.plainEnglishBottomLine || arr(bill.plainEnglishTakeaways).length) ? section('summary', 'In plain English', `
        <div class="bg-white border border-retro-border rounded-md p-6 lg:p-8">
          ${bill.plainEnglishBottomLine ? `<p class="text-xl text-retro-ink leading-relaxed mb-5">${esc(bill.plainEnglishBottomLine)}</p>` : ''}
          ${arr(bill.plainEnglishTakeaways).length ? `
            <ul class="space-y-2">
              ${arr(bill.plainEnglishTakeaways).map(item => `<li class="text-sm text-retro-ink flex gap-3"><span class="text-retro-green font-mono text-xs mt-1">→</span><span>${esc(item)}</span></li>`).join('')}
            </ul>
          ` : ''}
        </div>
      `) : '';

      const summary = bill.summary ? section('summary', 'Quick summary', `<p class="text-xl text-retro-ink leading-relaxed">${esc(bill.summary)}</p>`) : '';

      const keyNumbers = arr(bill.keyNumbers).length ? section('stats', 'Key numbers', `
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 border-t border-retro-border pt-6">
          ${arr(bill.keyNumbers).map(n => `
            <div>
              <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">${esc(n.label)}</p>
              <p class="text-2xl font-semibold text-retro-ink tracking-tight">${esc(n.value)}</p>
            </div>
          `).join('')}
        </div>
      `) : '';

      const whoAffected = arr(bill.whoAffected).length ? section('target', 'Who this affects', `
        <ul class="flex flex-wrap gap-2">
          ${arr(bill.whoAffected).map(w => `<li class="bg-white border border-retro-border rounded-sm px-3 py-1.5 text-sm text-retro-ink">${esc(w)}</li>`).join('')}
        </ul>
      `) : '';

      const parts = arr(bill.parts).length ? section('search', "What's in the bill", `
        <div class="space-y-6">
          ${arr(bill.parts).map(p => `
            <div class="bg-white border border-retro-border rounded-md p-6 lg:p-8">
              <h3 class="text-lg font-semibold text-retro-ink mb-4">${esc(p.name)}</h3>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div><p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">What it says</p><p class="text-sm text-retro-slate leading-relaxed">${esc(p.says)}</p></div>
                <div><p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">What it means</p><p class="text-sm text-retro-ink leading-relaxed">${esc(p.means)}</p></div>
                <div><p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">Who it affects</p><p class="text-sm text-retro-ink leading-relaxed">${esc(p.affects)}</p></div>
              </div>
            </div>
          `).join('')}
        </div>
      `) : '';

      const stakeholderImpacts = arr(bill.stakeholderImpacts).length ? section('people', 'Stakeholder impact', `
        <div class="border border-retro-border rounded-md bg-white overflow-hidden divide-y divide-retro-border">
          ${arr(bill.stakeholderImpacts).map(s => `
            <div class="p-6 lg:p-8">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-lg font-semibold text-retro-ink">${esc(s.group)}</h3>
                <span class="font-mono text-retro-green text-sm tracking-widest">${magnitudeDots(s.magnitude || 3)}</span>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                <div><p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-1">Now</p><p class="text-retro-slate leading-relaxed">${esc(s.current)}</p></div>
                <div><p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-1">After this bill</p><p class="text-retro-ink leading-relaxed">${esc(s.changes)}</p></div>
              </div>
              ${s.timeline ? `<p class="mt-3 text-[10px] font-mono text-retro-slate uppercase tracking-widest">Timeline · ${esc(s.timeline)}</p>` : ''}
            </div>
          `).join('')}
        </div>
      `) : '';

      const rights = arr(bill.rights).length ? section('scales', 'Rights & freedoms', `
        <div class="space-y-4">
          ${arr(bill.rights).map(r => `
            <div class="bg-white border border-retro-border rounded-md p-6">
              <div class="flex items-center justify-between gap-4 mb-2">
                <h3 class="font-semibold text-retro-ink">${esc(r.right)}</h3>
                <span class="text-[10px] font-mono uppercase tracking-widest ${effectColor(r.effect)}">${effectLabel(r.effect)}</span>
              </div>
              <p class="text-sm text-retro-slate leading-relaxed">${esc(r.analysis)}</p>
              ${r.safeguards ? `<p class="mt-3 text-sm text-retro-ink leading-relaxed"><span class="font-mono text-[10px] uppercase tracking-widest text-retro-green mr-2">Safeguards</span>${esc(r.safeguards)}</p>` : ''}
            </div>
          `).join('')}
        </div>
      `) : '';

      const scenarios = arr(bill.scenarios).length ? section('book', 'Before & after scenarios', `
        <div class="space-y-6">
          ${arr(bill.scenarios).map(sc => `
            <article class="bg-white border border-retro-border rounded-md p-6 lg:p-8">
              <h3 class="text-xl font-semibold text-retro-ink mb-1">${esc(sc.title)}</h3>
              <p class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-5">${esc(sc.stakeholder)}</p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
                <div><p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">Before</p><p class="text-sm text-retro-slate leading-relaxed">${esc(sc.before)}</p></div>
                <div><p class="text-[9px] font-mono text-retro-green uppercase tracking-widest mb-2">After</p><p class="text-sm text-retro-ink leading-relaxed">${esc(sc.after)}</p></div>
              </div>
              ${arr(sc.keyChanges).length ? `<div><p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">Key changes</p><ul class="space-y-1.5">${arr(sc.keyChanges).map(k => `<li class="text-sm text-retro-ink flex gap-2"><span class="text-retro-green font-mono text-xs mt-1">→</span><span>${esc(k)}</span></li>`).join('')}</ul></div>` : ''}
              ${arr(sc.numbers).length ? `<div class="mt-4 pt-3 border-t border-retro-border">${arr(sc.numbers).map(n => `<p class="text-[10px] font-mono text-retro-slate">${esc(n)}</p>`).join('')}</div>` : ''}
            </article>
          `).join('')}
        </div>
      `) : '';

      const timeline = arr(bill.timeline).length ? section('calendar', 'Implementation timeline', `
        <ol class="border-l-2 border-retro-green/30 pl-6 space-y-5">
          ${arr(bill.timeline).map(t => `
            <li class="relative">
              <span class="absolute -left-[31px] top-1.5 w-3 h-3 rounded-full bg-retro-green"></span>
              <p class="text-[10px] font-mono text-retro-green uppercase tracking-widest mb-1">${esc(t.when)}</p>
              <p class="text-sm text-retro-ink leading-relaxed">${esc(t.what)}</p>
            </li>
          `).join('')}
        </ol>
      `) : '';

      const actions = arr(bill.actions).length ? section('check', 'What you need to do', `
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          ${arr(bill.actions).map(a => `
            <div class="bg-white border border-retro-border rounded-md p-6">
              <h3 class="font-semibold text-retro-ink mb-4">${esc(a.label)}</h3>
              <ul class="space-y-2">
                ${arr(a.steps).map((s, i) => `<li class="text-sm text-retro-ink flex gap-3"><span class="font-mono text-retro-green text-xs mt-1">${String(i+1).padStart(2,'0')}</span><span>${esc(s)}</span></li>`).join('')}
              </ul>
            </div>
          `).join('')}
        </div>
      `) : '';

      const moneyTrail = arr(bill.moneyTrail).length ? section('pound', 'Money behind the bill', `
        <p class="text-sm text-retro-slate mb-6 max-w-2xl">Funding, lobbying, and ministerial meetings around this legislation.</p>
        <div class="bg-retro-ink text-white rounded-md p-6 lg:p-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-4">
            ${arr(bill.moneyTrail).map(m => `
              <div class="border-b border-white/10 pb-3">
                <p class="text-[9px] font-mono text-white/50 uppercase tracking-widest mb-1">${esc(m.label)}</p>
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-xl font-semibold tracking-tight">${esc(m.value)}</span>
                  <span class="text-[9px] font-mono text-retro-green uppercase tracking-widest">${esc(m.source)}</span>
                </div>
              </div>
            `).join('')}
          </div>
        </div>
      `) : '';

      const debate = bill.debate && (arr(bill.debate.supporters).length || arr(bill.debate.critics).length || bill.debate.neutral) ? section('speech', 'The debate', `
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          ${arr(bill.debate.supporters).length ? `
            <div class="bg-white border border-retro-border rounded-md p-6 border-t-4 border-t-retro-green">
              <h3 class="text-sm font-semibold text-retro-green uppercase tracking-widest mb-4">Supporters argue</h3>
              <ul class="space-y-3">${arr(bill.debate.supporters).map(s => `<li class="text-sm text-retro-ink leading-relaxed flex gap-2"><span class="text-retro-green mt-1">+</span><span>${esc(s)}</span></li>`).join('')}</ul>
            </div>` : ''}
          ${arr(bill.debate.critics).length ? `
            <div class="bg-white border border-retro-border rounded-md p-6 border-t-4 border-t-amber-700">
              <h3 class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: rgb(180, 83, 9);">Critics argue</h3>
              <ul class="space-y-3">${arr(bill.debate.critics).map(c => `<li class="text-sm text-retro-ink leading-relaxed flex gap-2"><span class="mt-1" style="color: rgb(180, 83, 9);">−</span><span>${esc(c)}</span></li>`).join('')}</ul>
            </div>` : ''}
        </div>
        ${bill.debate.neutral ? `<div class="bg-retro-bg border border-retro-border rounded-md p-6"><h3 class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2">Neutral analysis</h3><p class="text-sm text-retro-ink leading-relaxed">${esc(bill.debate.neutral)}</p></div>` : ''}
      `) : '';

      const redFlags = arr(bill.redFlags).length ? `
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-amber-700 uppercase tracking-[0.22em] mb-4 flex items-center gap-2">${iconSvg('warning', 'w-3.5 h-3.5', 'text-amber-700')}Red flags</h2>
          <ul class="space-y-2">
            ${arr(bill.redFlags).map(f => `<li class="text-sm text-retro-ink leading-relaxed flex gap-3 bg-amber-50 border border-amber-200 rounded-sm p-3">${iconSvg('warning', 'w-4 h-4', 'text-amber-700')}<span>${esc(f)}</span></li>`).join('')}
          </ul>
        </section>
      ` : '';

      const resources = arr(bill.resources).length ? section('library', 'Further resources', `
        <ul class="space-y-2">
          ${arr(bill.resources).map(r => `<li><a href="${esc(r.url)}" target="_blank" rel="noopener" class="text-retro-green hover:text-retro-ledger underline underline-offset-2 text-sm">${esc(r.label)} →</a></li>`).join('')}
        </ul>
      `) : '';

      const footer = `
        <footer class="mt-16 pt-6 border-t border-retro-ink/15 text-[9px] font-mono text-retro-slate uppercase tracking-[0.22em]">
          AI-translated by Kimi · cite legislation.gov.uk for legal use
        </footer>
      `;

        container.innerHTML = headerBlock + plainEnglish + summary + keyNumbers + whoAffected + parts + stakeholderImpacts + rights + scenarios + timeline + actions + moneyTrail + debate + redFlags + resources + footer;
        missing.classList.add('hidden');
        localStorage.setItem(ACTIVE_BILL_KEY, billId(bill));
        renderHistory(billId(bill));
      }

      const raw = sessionStorage.getItem(SESSION_CURRENT_KEY);
      if (raw) {
        try {
          saveBillHistory(JSON.parse(raw));
        } catch {}
      }

      const history = loadBillHistory();
      const activeId = localStorage.getItem(ACTIVE_BILL_KEY);
      const activeEntry = history.find(entry => entry.id === activeId) || history[0];

      if (!activeEntry) {
        missing.classList.remove('hidden');
        renderHistory(null);
        return;
      }

      renderBill(activeEntry.bill);

      historyContainer.addEventListener('click', (event) => {
        const target = event.target.closest('[data-bill-history-id]');
        if (!target) return;
        const nextId = target.getAttribute('data-bill-history-id');
        const nextEntry = loadBillHistory().find(entry => entry.id === nextId);
        if (!nextEntry) return;
        renderBill(nextEntry.bill);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    })();
  </script>
</LightLayout>
