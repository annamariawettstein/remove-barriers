---
export const prerender = true;
import LightLayout from '../../layouts/LightLayout.astro';
import { BILLS, billBySlug } from '../../data/bills';

export function getStaticPaths() {
  return BILLS.map(b => ({ params: { slug: b.slug } }));
}

const { slug } = Astro.params;
const bill = billBySlug(slug!);
if (!bill) return Astro.redirect('/bills');

const magnitudeDots = (n: number) => "●".repeat(n) + "○".repeat(5 - n);
const effectColor = (effect: string) => ({
  enhance: 'text-retro-green',
  restrict: 'text-amber-700',
  mixed: 'text-retro-slate'
}[effect] || 'text-retro-slate');
const effectLabel = (effect: string) => ({
  enhance: 'Strengthens',
  restrict: 'Restricts',
  mixed: 'Mixed effect'
}[effect] || effect);
---

<LightLayout title={`${bill.shortTitle} — Lattice`}>
  <main class="relative z-10 max-w-[1100px] mx-auto px-6 lg:px-8 py-12 bg-retro-bg" data-bill-slug={bill.slug}>

    <!-- Breadcrumb / back -->
    <div class="mb-8 text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] flex items-center gap-3">
      <a href="/" class="hover:text-retro-ink transition">Lattice</a>
      <span class="text-retro-ink/20">/</span>
      <a href="/bills" class="hover:text-retro-ink transition">Bills</a>
      <span class="text-retro-ink/20">/</span>
      <span class="text-retro-ink">{bill.shortTitle}</span>
    </div>

    <!-- Doc header strip -->
    <div class="border-t border-retro-ink/15 pt-3 flex items-center justify-between text-[9px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-10">
      <div class="flex items-center gap-5">
        <span>BILL · {bill.slug.toUpperCase()}</span>
        <span class="hidden md:inline">{bill.territorialExtent.join(' · ')}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-1 h-1 rounded-full bg-retro-green"></span>
        <span>{bill.status}</span>
      </div>
    </div>

    <!-- Title block -->
    <header class="mb-14">
      <div class="text-5xl mb-4">{bill.emoji}</div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold text-retro-ink tracking-tight leading-[1.05] mb-4">
        {bill.shortTitle}
      </h1>
      <p class="text-base text-retro-slate font-mono">{bill.fullTitle} · {bill.sponsoringDept}</p>
      <p class="mt-1 text-base text-retro-slate font-mono">Introduced {bill.introducedDate} · {bill.stageDetail}</p>
    </header>

    <!-- Personalise CTA -->
    <section class="mb-12 border border-retro-ink rounded-md bg-white p-6 lg:p-8 shadow-[4px_4px_0px_rgba(15,61,46,0.95)]">
      <div class="flex flex-col lg:flex-row gap-6 lg:items-center lg:justify-between">
        <div>
          <div class="text-[10px] font-mono text-retro-green uppercase tracking-[0.22em] mb-2">Optional · 30 seconds</div>
          <h2 class="text-xl font-semibold text-retro-ink mb-1">Personalise this brief for you</h2>
          <p class="text-sm text-retro-slate" id="personalise-status">
            Add a few details about your situation and we'll highlight the scenarios and actions that apply to you. Nothing is sent anywhere — saved only on this device.
          </p>
        </div>
        <div class="flex gap-3 flex-shrink-0">
          <button id="personalise-open" class="bg-retro-green text-white px-6 py-3 text-sm font-medium hover:bg-retro-ledger transition-colors rounded-sm shadow-[3px_3px_0px_rgba(15,61,46,1)] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px]">
            Personalise
          </button>
          <button id="personalise-clear" class="hidden text-retro-ink border border-retro-border bg-white px-4 py-3 text-sm font-medium hover:bg-retro-bg transition rounded-sm">
            Clear
          </button>
        </div>
      </div>
    </section>

    <!-- Quick Summary -->
    <section class="mb-14">
      <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-4">📋 Quick summary</h2>
      <p class="text-xl text-retro-ink leading-relaxed">{bill.summary}</p>
    </section>

    <!-- Key Numbers -->
    {bill.keyNumbers?.length ? (
      <section class="mb-14">
        <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-4">📊 Key numbers</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 border-t border-retro-border pt-6">
          {bill.keyNumbers.map(n => (
            <div>
              <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">{n.label}</p>
              <p class="text-2xl font-semibold text-retro-ink tracking-tight">{n.value}</p>
            </div>
          ))}
        </div>
      </section>
    ) : null}

    <!-- Who this affects -->
    {bill.whoAffected?.length ? (
      <section class="mb-14">
        <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-4">🎯 Who this affects</h2>
        <ul class="flex flex-wrap gap-2">
          {bill.whoAffected.map(w => (
            <li class="bg-white border border-retro-border rounded-sm px-3 py-1.5 text-sm text-retro-ink">{w}</li>
          ))}
        </ul>
      </section>
    ) : null}

    {bill.isStub ? (
      <section class="bg-retro-ink text-white rounded-md p-8 mt-8">
        <div class="text-[10px] font-mono text-retro-green uppercase tracking-[0.22em] mb-3">Coming soon</div>
        <h3 class="text-2xl font-semibold mb-2">Full plain-English analysis in preparation</h3>
        <p class="text-sm text-white/70">We're authoring this bill's full breakdown — stakeholder impact, scenarios, money trail, and what you need to do. Check back, or get an email when it's ready.</p>
      </section>
    ) : (
      <>

      <!-- What's in the bill -->
      {bill.parts?.length ? (
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-6">🔍 What's in the bill</h2>
          <div class="space-y-6">
            {bill.parts.map(part => (
              <div class="bg-white border border-retro-border rounded-md p-6 lg:p-8">
                <h3 class="text-lg font-semibold text-retro-ink mb-4">{part.name}</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                  <div>
                    <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">What it says</p>
                    <p class="text-sm text-retro-slate leading-relaxed">{part.says}</p>
                  </div>
                  <div>
                    <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">What it means</p>
                    <p class="text-sm text-retro-ink leading-relaxed">{part.means}</p>
                  </div>
                  <div>
                    <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">Who it affects</p>
                    <p class="text-sm text-retro-ink leading-relaxed">{part.affects}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      ) : null}

      <!-- Stakeholder impact -->
      {bill.stakeholderImpacts?.length ? (
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-6">👥 Stakeholder impact</h2>
          <div class="border border-retro-border rounded-md bg-white overflow-hidden divide-y divide-retro-border">
            {bill.stakeholderImpacts.map(s => (
              <div class="p-6 lg:p-8">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <h3 class="text-lg font-semibold text-retro-ink">{s.group}</h3>
                  <span class="font-mono text-retro-green text-sm tracking-widest" title={`Impact magnitude ${s.magnitude}/5`}>{magnitudeDots(s.magnitude)}</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                  <div>
                    <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-1">Now</p>
                    <p class="text-retro-slate leading-relaxed">{s.current}</p>
                  </div>
                  <div>
                    <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-1">After this bill</p>
                    <p class="text-retro-ink leading-relaxed">{s.changes}</p>
                  </div>
                </div>
                <p class="mt-3 text-[10px] font-mono text-retro-slate uppercase tracking-widest">Timeline · {s.timeline}</p>
              </div>
            ))}
          </div>
        </section>
      ) : null}

      <!-- Rights & freedoms -->
      {bill.rights?.length ? (
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-6">⚖️ Rights &amp; freedoms</h2>
          <div class="space-y-4">
            {bill.rights.map(r => (
              <div class="bg-white border border-retro-border rounded-md p-6">
                <div class="flex items-center justify-between gap-4 mb-2">
                  <h3 class="font-semibold text-retro-ink">{r.right}</h3>
                  <span class={`text-[10px] font-mono uppercase tracking-widest ${effectColor(r.effect)}`}>{effectLabel(r.effect)}</span>
                </div>
                <p class="text-sm text-retro-slate leading-relaxed">{r.analysis}</p>
                {r.safeguards ? (
                  <p class="mt-3 text-sm text-retro-ink leading-relaxed"><span class="font-mono text-[10px] uppercase tracking-widest text-retro-green mr-2">Safeguards</span>{r.safeguards}</p>
                ) : null}
              </div>
            ))}
          </div>
        </section>
      ) : null}

      <!-- Before & after scenarios (personalisable) -->
      {bill.scenarios?.length ? (
        <section class="mb-14">
          <div class="flex items-center justify-between gap-4 mb-6">
            <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em]">📖 Before &amp; after scenarios</h2>
            <span class="hidden lattice-personalised text-[9px] font-mono uppercase tracking-widest text-retro-green" id="scenarios-personalised-badge">Personalised for you</span>
          </div>
          <div class="space-y-6" id="scenarios-list">
            {bill.scenarios.map(sc => (
              <article class="bg-white border border-retro-border rounded-md p-6 lg:p-8 lattice-scenario"
                data-housing={JSON.stringify(sc.profileMatch?.housingTenure || [])}
                data-employment={JSON.stringify(sc.profileMatch?.employmentStatus || [])}>
                <h3 class="text-xl font-semibold text-retro-ink mb-1">{sc.title}</h3>
                <p class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-5">{sc.stakeholder}</p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
                  <div>
                    <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">Before</p>
                    <p class="text-sm text-retro-slate leading-relaxed">{sc.before}</p>
                  </div>
                  <div>
                    <p class="text-[9px] font-mono text-retro-green uppercase tracking-widest mb-2">After</p>
                    <p class="text-sm text-retro-ink leading-relaxed">{sc.after}</p>
                  </div>
                </div>
                <div>
                  <p class="text-[9px] font-mono text-retro-slate uppercase tracking-widest mb-2">Key changes</p>
                  <ul class="space-y-1.5">
                    {sc.keyChanges.map(k => (
                      <li class="text-sm text-retro-ink flex gap-2"><span class="text-retro-green font-mono text-xs mt-1">→</span><span>{k}</span></li>
                    ))}
                  </ul>
                </div>
                {sc.numbers?.length ? (
                  <div class="mt-4 pt-3 border-t border-retro-border">
                    {sc.numbers.map(n => (
                      <p class="text-[10px] font-mono text-retro-slate">{n}</p>
                    ))}
                  </div>
                ) : null}
              </article>
            ))}
          </div>
          <p id="scenarios-empty" class="hidden text-sm text-retro-slate italic mt-4">No scenarios match your profile yet — clear the filter to see all.</p>
        </section>
      ) : null}

      <!-- Implementation timeline -->
      {bill.timeline?.length ? (
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-6">📅 Implementation timeline</h2>
          <ol class="border-l-2 border-retro-green/30 pl-6 space-y-5">
            {bill.timeline.map(t => (
              <li class="relative">
                <span class="absolute -left-[31px] top-1.5 w-3 h-3 rounded-full bg-retro-green"></span>
                <p class="text-[10px] font-mono text-retro-green uppercase tracking-widest mb-1">{t.when}</p>
                <p class="text-sm text-retro-ink leading-relaxed">{t.what}</p>
              </li>
            ))}
          </ol>
        </section>
      ) : null}

      <!-- What you need to do (personalisable) -->
      {bill.actions?.length ? (
        <section class="mb-14">
          <div class="flex items-center justify-between gap-4 mb-6">
            <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em]">✅ What you need to do</h2>
            <span class="hidden lattice-personalised text-[9px] font-mono uppercase tracking-widest text-retro-green" id="actions-personalised-badge">Personalised for you</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="actions-list">
            {bill.actions.map(a => (
              <div class="bg-white border border-retro-border rounded-md p-6 lattice-action"
                data-housing={JSON.stringify(a.profileMatch?.housingTenure || [])}
                data-employment={JSON.stringify(a.profileMatch?.employmentStatus || [])}>
                <h3 class="font-semibold text-retro-ink mb-4">{a.label}</h3>
                <ul class="space-y-2">
                  {a.steps.map((s, i) => (
                    <li class="text-sm text-retro-ink flex gap-3">
                      <span class="font-mono text-retro-green text-xs mt-1">{String(i+1).padStart(2,'0')}</span>
                      <span>{s}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      ) : null}

      <!-- Money behind the bill (Lattice differentiator) -->
      {bill.moneyTrail?.length ? (
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-2">💷 Money behind the bill</h2>
          <p class="text-sm text-retro-slate mb-6 max-w-2xl">Follow the funding, lobbying and ministerial meetings around this legislation. Each figure links to the underlying public-record source.</p>
          <div class="bg-retro-ink text-white rounded-md p-6 lg:p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-4">
              {bill.moneyTrail.map(m => (
                <div class="border-b border-white/10 pb-3">
                  <p class="text-[9px] font-mono text-white/50 uppercase tracking-widest mb-1">{m.label}</p>
                  <div class="flex items-baseline justify-between gap-3">
                    <span class="text-xl font-semibold tracking-tight">{m.value}</span>
                    <span class="text-[9px] font-mono text-retro-green uppercase tracking-widest">{m.source}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      ) : null}

      <!-- The debate -->
      {bill.debate ? (
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-6">🗣️ The debate</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div class="bg-white border border-retro-border rounded-md p-6 border-t-4 border-t-retro-green">
              <h3 class="text-sm font-semibold text-retro-green uppercase tracking-widest mb-4">Supporters argue</h3>
              <ul class="space-y-3">
                {bill.debate.supporters.map(s => (
                  <li class="text-sm text-retro-ink leading-relaxed flex gap-2"><span class="text-retro-green mt-1">+</span><span>{s}</span></li>
                ))}
              </ul>
            </div>
            <div class="bg-white border border-retro-border rounded-md p-6 border-t-4 border-t-amber-700">
              <h3 class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: rgb(180, 83, 9);">Critics argue</h3>
              <ul class="space-y-3">
                {bill.debate.critics.map(c => (
                  <li class="text-sm text-retro-ink leading-relaxed flex gap-2"><span class="mt-1" style="color: rgb(180, 83, 9);">−</span><span>{c}</span></li>
                ))}
              </ul>
            </div>
          </div>
          <div class="bg-retro-bg border border-retro-border rounded-md p-6">
            <h3 class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2">Neutral analysis</h3>
            <p class="text-sm text-retro-ink leading-relaxed">{bill.debate.neutral}</p>
          </div>
        </section>
      ) : null}

      <!-- Red flags -->
      {bill.redFlags?.length ? (
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-amber-700 uppercase tracking-[0.22em] mb-4">⚠️ Red flags</h2>
          <ul class="space-y-2">
            {bill.redFlags.map(f => (
              <li class="text-sm text-retro-ink leading-relaxed flex gap-3 bg-amber-50 border border-amber-200 rounded-sm p-3"><span class="text-amber-700 mt-0.5">⚠</span><span>{f}</span></li>
            ))}
          </ul>
        </section>
      ) : null}

      <!-- Resources -->
      {bill.resources?.length ? (
        <section class="mb-14">
          <h2 class="text-[10px] font-mono text-retro-slate uppercase tracking-[0.22em] mb-4">📚 Further resources</h2>
          <ul class="space-y-2">
            {bill.resources.map(r => (
              <li><a href={r.url} target="_blank" rel="noopener" class="text-retro-green hover:text-retro-ledger underline underline-offset-2 text-sm">{r.label} →</a></li>
            ))}
          </ul>
        </section>
      ) : null}

      <!-- Footer strip -->
      <footer class="mt-16 pt-6 border-t border-retro-ink/15 flex flex-col md:flex-row gap-2 md:items-center md:justify-between text-[9px] font-mono text-retro-slate uppercase tracking-[0.22em]">
        <div class="flex flex-wrap gap-4">
          <span>Analysis status · {bill.status}</span>
          {bill.royalAssentExpected ? <span>Royal Assent expected · {bill.royalAssentExpected}</span> : null}
        </div>
        <div>Plain-English translation by Lattice · cite legislation.gov.uk for legal use</div>
      </footer>
      </>
    )}
  </main>

  <!-- Personalise Modal -->
  <div id="personalise-modal" class="fixed inset-0 z-[100] hidden bg-retro-ink/40 backdrop-blur-sm items-center justify-center p-4">
    <div class="bg-retro-bg border border-retro-ink rounded-md max-w-lg w-full p-8 shadow-[6px_6px_0px_rgba(15,61,46,0.95)]">
      <div class="flex items-start justify-between mb-6">
        <div>
          <div class="text-[10px] font-mono text-retro-green uppercase tracking-[0.22em] mb-1">Personalise</div>
          <h3 class="text-xl font-semibold text-retro-ink">Tell us a little about your situation</h3>
          <p class="text-sm text-retro-slate mt-1">Stored only on this device. Skip any question.</p>
        </div>
        <button id="personalise-close" class="text-retro-slate hover:text-retro-ink text-xl leading-none">×</button>
      </div>

      <form id="personalise-form" class="space-y-5">
        <div>
          <label class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2 block">Housing</label>
          <select name="housingTenure" class="w-full bg-white border border-retro-border rounded-sm px-3 py-2 text-sm text-retro-ink focus:outline-none focus:border-retro-green">
            <option value="">— not specified —</option>
            <option value="renter">Renting (private)</option>
            <option value="owner">Own outright</option>
            <option value="mortgage">Own with a mortgage</option>
            <option value="landlord">Landlord</option>
            <option value="family">Living with family</option>
          </select>
        </div>

        <div>
          <label class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2 block">Employment</label>
          <select name="employmentStatus" class="w-full bg-white border border-retro-border rounded-sm px-3 py-2 text-sm text-retro-ink focus:outline-none focus:border-retro-green">
            <option value="">— not specified —</option>
            <option value="employee">Employee</option>
            <option value="selfEmployed">Self-employed</option>
            <option value="businessOwner">Business owner</option>
            <option value="publicSector">Public sector worker</option>
            <option value="retired">Retired</option>
            <option value="student">Student</option>
          </select>
        </div>

        <div>
          <label class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2 block">Constituency <span class="text-retro-slate/70 normal-case tracking-normal text-[10px]">(optional · free text)</span></label>
          <input type="text" name="constituency" placeholder="e.g. Tottenham" class="w-full bg-white border border-retro-border rounded-sm px-3 py-2 text-sm text-retro-ink focus:outline-none focus:border-retro-green" />
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" class="flex-1 bg-retro-green text-white px-6 py-3 text-sm font-medium hover:bg-retro-ledger transition-colors rounded-sm shadow-[3px_3px_0px_rgba(15,61,46,1)] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px]">
            Save &amp; personalise
          </button>
          <button type="button" id="personalise-cancel" class="text-retro-ink border border-retro-border bg-white px-4 py-3 text-sm font-medium hover:bg-retro-bg transition rounded-sm">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    (function () {
      const STORAGE_KEY = 'lattice.profile';
      const modal = document.getElementById('personalise-modal');
      const form = document.getElementById('personalise-form');
      const openBtn = document.getElementById('personalise-open');
      const closeBtn = document.getElementById('personalise-close');
      const cancelBtn = document.getElementById('personalise-cancel');
      const clearBtn = document.getElementById('personalise-clear');
      const status = document.getElementById('personalise-status');
      const scenarios = document.querySelectorAll('.lattice-scenario');
      const actions = document.querySelectorAll('.lattice-action');
      const scenariosBadge = document.getElementById('scenarios-personalised-badge');
      const actionsBadge = document.getElementById('actions-personalised-badge');
      const scenariosEmpty = document.getElementById('scenarios-empty');

      function loadProfile() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
        catch { return {}; }
      }

      function saveProfile(p) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(p));
      }

      function clearProfile() {
        localStorage.removeItem(STORAGE_KEY);
      }

      function matchesProfile(itemTags, profile) {
        // itemTags has housing[] and employment[]. If both arrays empty, item is generic and shown by default
        // when no personalisation is active, hidden otherwise (unless explicitly matched on some field).
        const noTags = itemTags.housing.length === 0 && itemTags.employment.length === 0;
        if (noTags) return true; // generic items always show

        const housingMatch = itemTags.housing.length > 0 && profile.housingTenure && itemTags.housing.includes(profile.housingTenure);
        const employmentMatch = itemTags.employment.length > 0 && profile.employmentStatus && itemTags.employment.includes(profile.employmentStatus);
        return housingMatch || employmentMatch;
      }

      function applyPersonalisation() {
        const profile = loadProfile();
        const hasProfile = !!(profile.housingTenure || profile.employmentStatus || profile.constituency);

        if (clearBtn) clearBtn.classList.toggle('hidden', !hasProfile);
        if (openBtn) openBtn.textContent = hasProfile ? 'Edit profile' : 'Personalise';
        if (scenariosBadge) scenariosBadge.classList.toggle('hidden', !hasProfile);
        if (actionsBadge) actionsBadge.classList.toggle('hidden', !hasProfile);

        if (status) {
          if (hasProfile) {
            const tags = [];
            if (profile.housingTenure) tags.push(profile.housingTenure);
            if (profile.employmentStatus) tags.push(profile.employmentStatus);
            if (profile.constituency) tags.push(profile.constituency);
            status.textContent = `Personalised for: ${tags.join(' · ')}. Scenarios and actions matching your situation are highlighted; the rest are dimmed.`;
          } else {
            status.textContent = "Add a few details about your situation and we'll highlight the scenarios and actions that apply to you. Nothing is sent anywhere — saved only on this device.";
          }
        }

        function applyToList(items) {
          let shownCount = 0;
          items.forEach(el => {
            const tags = {
              housing: JSON.parse(el.dataset.housing || '[]'),
              employment: JSON.parse(el.dataset.employment || '[]'),
            };
            if (!hasProfile) {
              el.classList.remove('lattice-dimmed', 'lattice-match');
              shownCount++;
              return;
            }
            const matches = matchesProfile(tags, profile);
            el.classList.toggle('lattice-match', matches);
            el.classList.toggle('lattice-dimmed', !matches);
            if (matches) shownCount++;
          });
          return shownCount;
        }

        const matchedScenarios = applyToList(scenarios);
        applyToList(actions);
        if (scenariosEmpty) scenariosEmpty.classList.toggle('hidden', matchedScenarios > 0);
      }

      function openModal() {
        const profile = loadProfile();
        form.housingTenure.value = profile.housingTenure || '';
        form.employmentStatus.value = profile.employmentStatus || '';
        form.constituency.value = profile.constituency || '';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      }

      function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }

      if (openBtn) openBtn.addEventListener('click', openModal);
      if (closeBtn) closeBtn.addEventListener('click', closeModal);
      if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
      if (modal) modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

      if (clearBtn) clearBtn.addEventListener('click', () => {
        clearProfile();
        applyPersonalisation();
      });

      if (form) form.addEventListener('submit', (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const profile = {
          housingTenure: data.get('housingTenure') || undefined,
          employmentStatus: data.get('employmentStatus') || undefined,
          constituency: (data.get('constituency') || '').toString().trim() || undefined,
        };
        // Strip undefined for clean storage
        const clean = Object.fromEntries(Object.entries(profile).filter(([_, v]) => v !== undefined));
        if (Object.keys(clean).length === 0) {
          clearProfile();
        } else {
          saveProfile(clean);
        }
        applyPersonalisation();
        closeModal();
      });

      applyPersonalisation();
    })();
  </script>

  <style>
    .lattice-dimmed { opacity: 0.32; filter: saturate(0.6); }
    .lattice-match { box-shadow: 4px 4px 0 rgba(15, 61, 46, 0.95); border-color: #0F3D2E; }
  </style>
</LightLayout>
