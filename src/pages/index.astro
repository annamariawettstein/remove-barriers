  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import * as THREE from 'three';
    import { CSS3DRenderer, CSS3DObject } from 'three/addons/renderers/CSS3DRenderer.js';
    import { prepareWithSegments, measureNaturalWidth } from '@chenglou/pretext';

    gsap.registerPlugin(ScrollTrigger);

    // --- Observer API (Basic Revealer) ---
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 },
    );
    document.querySelectorAll('.reveal').forEach((element) => observer.observe(element));

    // --- Problem Section Text Reveal ---
    gsap.utils.toArray('.gsap-problem-item').forEach((item: any, i) => {
        gsap.from(item, {
            scrollTrigger: {
                trigger: item,
                start: "top 85%",
            },
            opacity: 0,
            x: -20,
            duration: 0.6,
            ease: "power2.out",
            delay: i * 0.1
        });
    });

    // --- How It Works Pinned Scroll Animation ---
    const pinContainer = document.querySelector('#pin-container');
    const scrollSpace = document.querySelector('#scroll-space');
    
    if (pinContainer && scrollSpace) {
        // Pin the container
        ScrollTrigger.create({
            trigger: pinContainer,
            start: "top top",
            endTrigger: scrollSpace,
            end: "bottom bottom",
            pin: true,
            pinSpacing: false
        });

        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: pinContainer,
                start: "top top",
                endTrigger: scrollSpace,
                end: "bottom bottom",
                scrub: 1,
            }
        });

        // Step 1 -> Step 2
        tl.to("#step-1", { opacity: 0, y: -50, duration: 1 })
          .to("#step-2", { opacity: 1, y: 0, duration: 1 }, "-=0.5")
          .to("#ui-1", { opacity: 0, y: -50, duration: 1 }, "-=1")
          .to("#ui-2", { opacity: 1, y: 0, duration: 1 }, "-=0.5");

        // Step 2 -> Step 3
        tl.to("#step-2", { opacity: 0, y: -50, duration: 1 }, "+=1") // Wait a bit
          .to("#step-3", { opacity: 1, y: 0, duration: 1 }, "-=0.5")
          .to("#ui-2", { opacity: 0, y: -50, duration: 1 }, "-=1")
          .to("#ui-3", { opacity: 1, y: 0, duration: 1 }, "-=0.5");
          
        tl.to({}, {duration: 1}); // padding at end
    }

    // --- Contract Parsing Agent Animation ---
    const parseTl = gsap.timeline({
        scrollTrigger: { trigger: "#contract-parsing-card", start: "top 80%" },
        repeat: -1,
        repeatDelay: 2
    });

    parseTl.set(".gsap-parsing-status", { innerText: "ANALYZING...", color: "#0F3D2E", borderColor: "#0F3D2E", backgroundColor: "rgba(15,61,46,0.05)" })
           .fromTo(".gsap-scan-laser", { top: "-3px" }, { top: "100%", duration: 2.5, ease: "linear" });

    parseTl.addLabel("hit-term-1", 0.8)
           .to(".gsap-doc-highlight-1", { x: "0%", duration: 0.2, ease: "power2.out" }, "hit-term-1")
           .fromTo(".gsap-extracted-term-1", { opacity: 0, x: -10 }, { opacity: 1, x: 0, duration: 0.4, ease: "power2.out" }, "hit-term-1+=0.2");

    parseTl.addLabel("hit-term-2", 1.8)
           .to(".gsap-doc-highlight-2", { x: "0%", duration: 0.2, ease: "power2.out" }, "hit-term-2")
           .fromTo(".gsap-extracted-term-2", { opacity: 0, x: -10 }, { opacity: 1, x: 0, duration: 0.4, ease: "power2.out" }, "hit-term-2+=0.2");

    parseTl.to(".gsap-parsing-status", { innerText: "COMPLETE", color: "#1A5B43", borderColor: "rgba(26,91,67,0.3)", backgroundColor: "rgba(26,91,67,0.1)" }, 2.5)
           .fromTo(".gsap-confidence-score",
               { textContent: "0" },
               {
                   textContent: "98",
                   duration: 0.5,
                   snap: { textContent: 1 },
                   ease: "power1.out",
                   onUpdate: function() {
                       const el = document.querySelector('.gsap-confidence-score');
                       if (el) { el.innerHTML = this.targets()[0].textContent + '%'; el.classList.add('text-retro-green'); el.classList.remove('text-retro-slate'); }
                   }
               }, 2.5);

    parseTl.to(".gsap-parsing-status", { innerText: "AWAITING_DOC", color: "#6B7280", borderColor: "#E5E7EB", backgroundColor: "#F6F7E8", delay: 1.5 })
           .set([".gsap-extracted-term-1", ".gsap-extracted-term-2"], { opacity: 0 })
           .set([".gsap-doc-highlight-1", ".gsap-doc-highlight-2"], { x: "-100%" })
           .set(".gsap-confidence-score", { textContent: "--%", className: "gsap-confidence-score text-retro-slate font-mono font-bold" });


    // --- Three.js Wireframe Globe ---
    const container = document.getElementById('bg-globe-canvas') as HTMLCanvasElement;
    if (container) {
        const scene = new THREE.Scene();
        scene.background = null;

        const camera = new THREE.PerspectiveCamera(35, container.clientWidth / container.clientHeight, 0.1, 1000);
        camera.position.z = 25;

        const renderer = new THREE.WebGLRenderer({ canvas: container, antialias: true, alpha: true });
        renderer.setSize(container.clientWidth, container.clientHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        const geometry = new THREE.SphereGeometry(8, 64, 64);
        const material = new THREE.LineBasicMaterial({ color: 0x0A2E1F, transparent: true, opacity: 0.15 });
        const edges = new THREE.EdgesGeometry(geometry);
        const globe = new THREE.LineSegments(edges, material);
        scene.add(globe);

        const dotGeo = new THREE.BufferGeometry();
        const dotCount = 50;
        const positions = new Float32Array(dotCount * 3);
        
        for(let i=0; i<dotCount; i++) {
            const u = Math.random();
            const v = Math.random();
            const theta = u * 2.0 * Math.PI;
            const phi = Math.acos(2.0 * v - 1.0);
            const r = 8.02;
            
            positions[i*3] = r * Math.sin(phi) * Math.cos(theta);
            positions[i*3+1] = r * Math.sin(phi) * Math.sin(theta);
            positions[i*3+2] = r * Math.cos(phi);
        }
        
        dotGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        const dotMat = new THREE.PointsMaterial({ color: 0x0A2E1F, size: 0.05, transparent: true, opacity: 0.6 });
        const dots = new THREE.Points(dotGeo, dotMat);
        scene.add(dots);

        function animate() {
            requestAnimationFrame(animate);
            globe.rotation.y -= 0.0005;
            globe.rotation.x += 0.0002;
            dots.rotation.y -= 0.0005;
            dots.rotation.x += 0.0002;
            renderer.render(scene, camera);
        }

        animate();

        window.addEventListener('resize', () => {
            if(container) {
                camera.aspect = container.clientWidth / container.clientHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(container.clientWidth, container.clientHeight);
            }
        });
    }
    // --- Interactive 3D Data Warehouse Schema (Three.js, Blueprint Style) ---
    const schemaStage = document.getElementById('schema-stage') as HTMLElement | null;
    const schemaCanvas = document.getElementById('schema-canvas') as HTMLCanvasElement | null;
    const labelLayer  = document.getElementById('schema-labels') as HTMLElement | null;
    if (schemaStage && schemaCanvas && labelLayer) {
        const tooltip = document.getElementById('schema-tooltip')!;
        const ttTitle  = document.getElementById('tt-title')!;
        const ttCols   = document.getElementById('tt-cols')!;
        const ttRows   = document.getElementById('tt-rows')!;
        const ttSync   = document.getElementById('tt-sync')!;
        const ttFresh  = document.getElementById('tt-fresh')!;
        const ttFeeds  = document.getElementById('tt-feeds')!;
        const ttFrom   = document.getElementById('tt-from')!;
        const ttPin    = document.getElementById('tt-pin')!;

        type Col = { name: string; type: string; pk?: boolean; fk?: boolean };
        type Group = 'core' | 'payment' | 'contract' | 'output';
        type Tier  = 'focal' | 'middle' | 'outer';
        type NodeMeta = { lastSync: string; freshness: string };
        type Node = { id: string; label: string; group: Group; tier: Tier; x: number; y: number; z: number; cols: Col[]; rows: string; meta: NodeMeta };

        const groupColor: Record<Group, number> = {
            core:     0x0F3D2E,
            payment:  0x1A5B43,
            contract: 0x8B5E3C,
            output:   0x4F46E5,
        };
        const groupHex: Record<Group, string> = {
            core:     '#0F3D2E',
            payment:  '#1A5B43',
            contract: '#8B5E3C',
            output:   '#4F46E5',
        };

        // Hub-and-spoke arrangement: influence_graph is the focal node (lower-center, forward).
        // Middle tier (people + money): politicians, donors, donations.
        // Outer tier (organisations + sketchy money): companies, nonprofits, investments, ownership.
        const nodes: Node[] = [
            { id:'influence_graph', label:'influence_graph', group:'output',   tier:'focal',  x: 0.1, y:-0.8, z: 0.6,
              cols:[{name:'graph_id',type:'BIGINT',pk:true},{name:'node_a_id',type:'INT',fk:true},{name:'node_b_id',type:'INT',fk:true},{name:'tie_type',type:'VARCHAR'},{name:'strength',type:'DECIMAL'},{name:'period',type:'DATE'},{name:'updated_at',type:'TIMESTAMP'}],
              rows:'Live view',          meta:{ lastSync:'streaming',  freshness:'real-time' } },

