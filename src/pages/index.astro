        ];

        const edges: [string,string][] = [
            ['donations','politicians'],['donations','donors'],
            ['donors','companies'],['donors','nonprofits'],
            ['investments','companies'],['investments','ownership'],
            ['companies','ownership'],['nonprofits','ownership'],
            ['politicians','influence_graph'],['donors','influence_graph'],
            ['donations','influence_graph'],['companies','influence_graph'],
            ['nonprofits','influence_graph'],['investments','influence_graph'],['ownership','influence_graph'],
        ];

        const SPACING = 1.7;
        const BOX_D = 0.5;
        // Tier-based widths — focal larger, outer smaller. Boxes never resize on hover/click.
        const TIER_BOX_W: Record<Tier, number> = { focal: 1.95, middle: 1.55, outer: 1.30 };
        const boxWidthFor = (n: Node) => TIER_BOX_W[n.tier];

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(36, schemaStage.clientWidth / schemaStage.clientHeight, 0.1, 100);
        const renderer = new THREE.WebGLRenderer({ canvas: schemaCanvas, antialias: true, alpha: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x000000, 0);

        // CSS3DRenderer for HTML cards that rotate in real 3D space with the scene
        const css3d = new CSS3DRenderer();
        css3d.setSize(schemaStage.clientWidth, schemaStage.clientHeight);
        css3d.domElement.style.position = 'absolute';
        css3d.domElement.style.top = '0';
        css3d.domElement.style.left = '0';
        css3d.domElement.style.width = '100%';
        css3d.domElement.style.height = '100%';
        css3d.domElement.style.pointerEvents = 'none';
        labelLayer.appendChild(css3d.domElement);

        const root = new THREE.Group();
        scene.add(root);

        // Architectural floor grid (kept faint — atmospheric depth, not competing structure)
        const floor = new THREE.GridHelper(22, 22, 0x1A1A1A, 0x1A1A1A);
        (floor.material as THREE.LineBasicMaterial).transparent = true;
        (floor.material as THREE.LineBasicMaterial).opacity = 0.06;
        floor.position.y = -2.6;
        root.add(floor);

        // Back wall grid — even quieter
        const back = new THREE.GridHelper(16, 16, 0x1A1A1A, 0x1A1A1A);
        (back.material as THREE.LineBasicMaterial).transparent = true;
        (back.material as THREE.LineBasicMaterial).opacity = 0.035;
        back.rotation.x = Math.PI / 2;
        back.position.z = -5;
        root.add(back);


        // Table wireframe boxes (the architectural cages) + CSS3D HTML cards
        type BoxEntry = {
            node: Node;
            outerMat: THREE.LineBasicMaterial;
            innerMat: THREE.LineBasicMaterial;
            fillMat: THREE.MeshBasicMaterial;
            hitMesh: THREE.Mesh;
            group: THREE.Group;
            labelEl: HTMLDivElement;
            worldPos: THREE.Vector3;
            boxW: number;
            boxH: number;
            colWorldH: number; // world-space height of each column row
            cardOffsetTop: number; // world units from top of card to first column row
        };
        const boxes: BoxEntry[] = [];

        // Hidden measurement host so we can read the natural pixel height of each card
        const measureHost = document.createElement('div');
        measureHost.style.cssText = 'position:absolute; visibility:hidden; pointer-events:none; left:-9999px; top:0;';
        document.body.appendChild(measureHost);

        for (const n of nodes) {
            const g = new THREE.Group();

            // HTML card markup — cap visible columns to 4 by default; reveal the rest on hover
            const DEFAULT_VISIBLE = 4;
            const visibleCols = n.cols.slice(0, DEFAULT_VISIBLE);
            const extraCols   = n.cols.slice(DEFAULT_VISIBLE);
            const tierClass   = `is-${n.tier}`;

            const el = document.createElement('div');
            el.className = `schema-label ${tierClass}`;
            el.dataset.table = n.id;
            el.innerHTML = `
                <div class="schema-card" style="--accent:${groupHex[n.group]}">
                    <div class="schema-card-header">
                        <span>${n.label}</span>
                        <span class="schema-card-rows">${n.rows}</span>
                    </div>
                    <div class="schema-card-body">
                        ${visibleCols.map(c => `
                            <div class="schema-col ${c.pk?'is-pk':c.fk?'is-fk':''}" data-col="${c.name}">
                                <span class="schema-col-tag">${c.pk?'PK':c.fk?'FK':''}</span>
                                <span class="schema-col-name">${c.name}</span>
                                <span class="schema-col-type">${c.type}</span>
                            </div>`).join('')}
                        ${extraCols.length ? `<div class="schema-col-more">+ ${extraCols.length} more</div>` : ''}
                        ${extraCols.map(c => `
                            <div class="schema-col is-extra ${c.pk?'is-pk':c.fk?'is-fk':''}" data-col="${c.name}">
                                <span class="schema-col-tag">${c.pk?'PK':c.fk?'FK':''}</span>
                                <span class="schema-col-name">${c.name}</span>
                                <span class="schema-col-type">${c.type}</span>
                            </div>`).join('')}
                    </div>
                </div>`;

            // Measure pixel dimensions in normal flow
            measureHost.appendChild(el);
            const cardPxW = el.offsetWidth || 178;
            const cardPxH = el.offsetHeight || 120;
            const headerEl = el.querySelector('.schema-card-header') as HTMLElement;
            const firstColEl = el.querySelector('.schema-col') as HTMLElement;
            const headerPxH = headerEl?.offsetHeight ?? 22;
            const colPxH = firstColEl?.offsetHeight ?? 15;
            measureHost.removeChild(el);

            const boxW = boxWidthFor(n);
            const scale = boxW / cardPxW;
            const boxH = cardPxH * scale;
            const colWorldH = colPxH * scale;
            const cardOffsetTop = headerPxH * scale;

            // Translucent paper-colored fill — defines the box volume without obscuring the structure
            const fillMat = new THREE.MeshBasicMaterial({
                color: 0xFBFCEE,
                transparent: true,
                opacity: 0.32,
                side: THREE.DoubleSide,
                depthWrite: false,
            });
            const fillMesh = new THREE.Mesh(new THREE.BoxGeometry(boxW * 0.995, boxH * 0.995, BOX_D * 0.995), fillMat);
            fillMesh.renderOrder = -1; // draw underneath the cage lines
            g.add(fillMesh);

            // Outer pencil-stroke cage
            const outerGeo = new THREE.BoxGeometry(boxW, boxH, BOX_D);
            const outerEdges = new THREE.EdgesGeometry(outerGeo);
            const outerMat = new THREE.LineBasicMaterial({ color: 0x1A1A1A, transparent: true, opacity: 0.55 });
            g.add(new THREE.LineSegments(outerEdges, outerMat));

            // Inner colored cage — group accent
            const innerGeo = new THREE.BoxGeometry(boxW - 0.08, boxH - 0.06, BOX_D - 0.10);
            const innerEdges = new THREE.EdgesGeometry(innerGeo);
            const innerMat = new THREE.LineBasicMaterial({ color: groupColor[n.group], transparent: true, opacity: 0.30 });
            g.add(new THREE.LineSegments(innerEdges, innerMat));

            // Invisible hit mesh for raycasting
            const hitGeo = new THREE.BoxGeometry(boxW, boxH, BOX_D);
            const hitMat = new THREE.MeshBasicMaterial({ visible: false });
            const hitMesh = new THREE.Mesh(hitGeo, hitMat);
            g.add(hitMesh);

            // CSS3D card lives on the front face of the cage and rotates with it
            const cardObj = new CSS3DObject(el);
            cardObj.position.set(0, 0, BOX_D / 2 + 0.001);
            cardObj.scale.set(scale, scale, scale);
            g.add(cardObj);

            // Mirror card on the back face so the table is readable from both sides
            const elBack = el.cloneNode(true) as HTMLDivElement;
            elBack.classList.add('schema-label-back');
            const cardObjBack = new CSS3DObject(elBack);
            cardObjBack.position.set(0, 0, -(BOX_D / 2 + 0.001));
            cardObjBack.rotation.y = Math.PI;
            cardObjBack.scale.set(scale, scale, scale);
            g.add(cardObjBack);

            g.position.set(n.x * SPACING, n.y * SPACING, n.z * SPACING);
            root.add(g);

            boxes.push({ node: n, outerMat, innerMat, fillMat, hitMesh, group: g, labelEl: el, worldPos: new THREE.Vector3(), boxW, boxH, colWorldH, cardOffsetTop });
        }

        document.body.removeChild(measureHost);

        // Edges as quadratic-bezier sketch lines
        type EdgeEntry = { aId: string; bId: string; mat: THREE.LineBasicMaterial };
        const edges3D: EdgeEntry[] = [];
        for (const [aid, bid] of edges) {
            const a = nodes.find(x=>x.id===aid)!;
            const b = nodes.find(x=>x.id===bid)!;
            const start = new THREE.Vector3(a.x*SPACING, a.y*SPACING, a.z*SPACING);
            const end   = new THREE.Vector3(b.x*SPACING, b.y*SPACING, b.z*SPACING);
            const geo = new THREE.BufferGeometry().setFromPoints([start, end]);
            const mat = new THREE.LineBasicMaterial({ color: 0x1A1A1A, transparent: true, opacity: 0.07 });
            root.add(new THREE.Line(geo, mat));
            edges3D.push({ aId: aid, bId: bid, mat });
        }

        // Interaction state
        const raycaster = new THREE.Raycaster();
        const mouseNDC = new THREE.Vector2(-2, -2);
        let mouseScreenX = 0, mouseScreenY = 0;
        let hoveredId: string | null = null;

        let isDragging = false, lastX = 0, lastY = 0;
        let targetRotY = 0.55, targetRotX = 0.22, rotY = 0.55, rotX = 0.22;
        let targetZoom = 1.0, zoom = 1.0;

        // Insight-cycle state (driven outside the tick loop)
        const activeTables = new Set<string>();
        const activeEdgeKeys = new Set<string>();

        // Click-to-pin state for the detail tooltip
        let pinnedId: string | null = null;
        let downX = 0, downY = 0, downTime = 0;

        // --- Agent reasoning traces (animated straight lines between specific columns) ---
        type Trace = {
            start: THREE.Vector3;
            end: THREE.Vector3;
            startTime: number;
            duration: number;
            line: THREE.Line;
            mat: THREE.LineBasicMaterial;
            geo: THREE.BufferGeometry;
        };
        const traceLines: Trace[] = [];

        // Position of a specific column row on a table, in root's local frame
        // (each box group is a direct child of root with translation only, so we
        // can add the local offset to the group's position without using matrices).
        function colLocalPos(table: string, col: string, side: 'in' | 'out'): THREE.Vector3 {
            const b = boxes.find(x => x.node.id === table)!;
            const idx = Math.max(0, b.node.cols.findIndex(c => c.name === col));
            const numCols = b.node.cols.length;
            const colsArea = b.boxH - b.cardOffsetTop;
            const yLocal = (b.boxH / 2) - b.cardOffsetTop - (idx + 0.5) * (colsArea / numCols);
            const xLocal = (side === 'out' ? 1 : -1) * (b.boxW / 2 + 0.04);
            return new THREE.Vector3(
                b.group.position.x + xLocal,
                b.group.position.y + yLocal,
                b.group.position.z + BOX_D / 2,
            );
        }

        function addTrace(fromTable: string, fromCol: string, toTable: string, toCol: string) {
            const fromCenter = boxes.find(x => x.node.id === fromTable)!.node.x;
            const toCenter   = boxes.find(x => x.node.id === toTable)!.node.x;
            const fromSide: 'in' | 'out' = toCenter >= fromCenter ? 'out' : 'in';
            const toSide:   'in' | 'out' = toCenter >= fromCenter ? 'in'  : 'out';
            const start = colLocalPos(fromTable, fromCol, fromSide);
            const end   = colLocalPos(toTable,   toCol,   toSide);

            const mat = new THREE.LineBasicMaterial({ color: 0x0F3D2E, transparent: true, opacity: 0.92 });
            // Two-vertex buffer: we animate the second vertex from start → end to "draw" the line
            const geo = new THREE.BufferGeometry();
            const positions = new Float32Array(6);
            positions[0] = start.x; positions[1] = start.y; positions[2] = start.z;
            positions[3] = start.x; positions[4] = start.y; positions[5] = start.z;
            geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            const line = new THREE.Line(geo, mat);
            root.add(line);

            traceLines.push({ start, end, startTime: performance.now(), duration: 650, line, mat, geo });
        }

        function updateTrace(tr: Trace) {
            const t = Math.min(1, (performance.now() - tr.startTime) / tr.duration);
            const eased = t < 1 ? 1 - Math.pow(1 - t, 3) : 1;
            const arr = (tr.geo.attributes.position as THREE.BufferAttribute).array as Float32Array;
            // Animate the end vertex along the straight segment from start → end
            arr[3] = tr.start.x + (tr.end.x - tr.start.x) * eased;
            arr[4] = tr.start.y + (tr.end.y - tr.start.y) * eased;
            arr[5] = tr.start.z + (tr.end.z - tr.start.z) * eased;
            (tr.geo.attributes.position as THREE.BufferAttribute).needsUpdate = true;
            // Steady opacity once drawn — no pulsing
            if (t >= 1) tr.mat.opacity = 0.85;
        }

        function clearTraces() {
            for (const tr of traceLines) {
                root.remove(tr.line);
                tr.geo.dispose();
                tr.mat.dispose();
            }
            traceLines.length = 0;
        }

        schemaCanvas.addEventListener('mousedown', (e) => {
            isDragging = true;
            lastX = e.clientX; lastY = e.clientY;
            downX = e.clientX; downY = e.clientY;
            downTime = performance.now();
        });
        window.addEventListener('mouseup', (e) => {
            if (isDragging) {
                const dx = e.clientX - downX, dy = e.clientY - downY;
                const moved = Math.sqrt(dx * dx + dy * dy);
                const dt    = performance.now() - downTime;
                // Treat short, low-movement releases as clicks → toggle pinned card
                if (moved < 6 && dt < 400) {
                    pinnedId = (hoveredId && pinnedId === hoveredId) ? null : hoveredId;
                }
            }
            isDragging = false;
        });
        window.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            targetRotY += (e.clientX - lastX) * 0.006;
            targetRotX = Math.max(-0.7, Math.min(0.7, targetRotX + (e.clientY - lastY) * 0.005));
            lastX = e.clientX; lastY = e.clientY;
        });
        schemaCanvas.addEventListener('wheel', (e) => {
            e.preventDefault();
            targetZoom = Math.max(0.5, Math.min(2.4, targetZoom - e.deltaY * 0.001));
        }, { passive: false });

        schemaCanvas.addEventListener('mousemove', (e) => {
            const r = schemaCanvas.getBoundingClientRect();
            mouseScreenX = e.clientX - r.left;
            mouseScreenY = e.clientY - r.top;
            mouseNDC.x =  (mouseScreenX / r.width)  * 2 - 1;
            mouseNDC.y = -(mouseScreenY / r.height) * 2 + 1;
        });
        schemaCanvas.addEventListener('mouseleave', () => {
            mouseNDC.set(-2, -2);
            hoveredId = null;
            tooltip.style.opacity = '0';
        });

        function resize() {
            const w = schemaStage!.clientWidth, h = schemaStage!.clientHeight;
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
            renderer.setSize(w, h, false);
            css3d.setSize(w, h);
        }
        window.addEventListener('resize', resize);
        resize();

        function tick() {
            try {
            rotY  += (targetRotY  - rotY)  * 0.08;
            rotX  += (targetRotX  - rotX)  * 0.08;
            zoom  += (targetZoom  - zoom)  * 0.08;
            // No auto-sway — the scene only moves when the user drags / scrolls.

            root.rotation.y = rotY;
            root.rotation.x = rotX;
            camera.position.set(0, 0, 11 / zoom);
            camera.lookAt(0, 0, 0);

            // Hover detection (against invisible hit meshes inside each cage)
            raycaster.setFromCamera(mouseNDC, camera);
            const hits = raycaster.intersectObjects(boxes.map(b => b.hitMesh), false);
            const hitMesh = hits[0]?.object;
            const hit = hitMesh ? boxes.find(b => b.hitMesh === hitMesh) || null : null;
            hoveredId = hit ? hit.node.id : null;

            const stageW = schemaStage!.clientWidth, stageH = schemaStage!.clientHeight;

            // Visual hierarchy baselines by tier — every table stays readable; tier just nudges weight.
            const baseByTier: Record<Tier, { outer: number; inner: number }> = {
                focal:  { outer: 0.90, inner: 0.55 },
                middle: { outer: 0.78, inner: 0.45 },
                outer:  { outer: 0.62, inner: 0.32 },
            };
            const hasActiveInsight = activeTables.size > 0;

            for (const b of boxes) {
                b.group.getWorldPosition(b.worldPos);

                const isHov    = hoveredId === b.node.id;
                const isPinned = pinnedId  === b.node.id;
                const isActive = activeTables.has(b.node.id) || isPinned;
                const isDimmed = hasActiveInsight && !isActive && !isHov;

                // Atmospheric fade — distant nodes recede
                const dist = camera.position.distanceTo(b.worldPos);
                const fade = THREE.MathUtils.clamp((14.5 - dist) / 6, 0.55, 1);

                // Compute cage + fill opacities
                // Non-involved tables during an insight stay readable (just slightly muted)
                // so the active ones can glow brighter rather than dimming the rest into the floor.
                let outerOp: number, innerOp: number, fillOp: number;
                const base = baseByTier[b.node.tier];
                if (isHov)         { outerOp = 0.98;          innerOp = 0.88;          fillOp = 0.45; }
                else if (isActive) { outerOp = 0.95;          innerOp = 0.82;          fillOp = 0.48; }
                else if (isDimmed) { outerOp = base.outer * 0.78; innerOp = base.inner * 0.78; fillOp = 0.28; }
                else               { outerOp = base.outer;   innerOp = base.inner;   fillOp = 0.34; }
                b.outerMat.opacity = outerOp * fade;
                b.innerMat.opacity = innerOp * fade;
                b.fillMat.opacity  = fillOp * (0.78 + 0.22 * fade);

                // Card opacity — keep cards readable even when dimmed; active cards pop via cage brightness instead
                const cardOp = isDimmed ? 0.65 : (0.78 + 0.22 * fade);

                // Toggle classes + opacity on every copy of this table's card (front + back)
                labelLayer!.querySelectorAll<HTMLElement>(`.schema-label[data-table="${b.node.id}"]`).forEach(el => {
                    el.classList.toggle('is-hovered', isHov);
                    el.classList.toggle('is-active', isActive && !isHov);
                    el.classList.toggle('is-pinned', isPinned && !isHov);
                    el.classList.toggle('is-dimmed', isDimmed);
                    el.style.opacity = String(cardOp);
                });
            }

            // Edge emphasis — quieter inactive, stronger active
            for (const e of edges3D) {
                const lit = hoveredId === e.aId || hoveredId === e.bId;
                const insightLit = activeEdgeKeys.has(`${e.aId}|${e.bId}`) || activeEdgeKeys.has(`${e.bId}|${e.aId}`);
                e.mat.opacity = lit ? 0.78 : insightLit ? 0.55 : (hasActiveInsight ? 0.03 : 0.07);
                e.mat.color.setHex(lit || insightLit ? 0x0F3D2E : 0x1A1A1A);
            }

            // Trace lines (agent reasoning) — draw progress 0 → 1
            for (const tr of traceLines) updateTrace(tr);

            // Tooltip — hover wins; if nothing is hovered but a card is pinned, anchor it to that card
            const detailId = hoveredId || pinnedId;
            if (detailId) {
                const b = boxes.find(x => x.node.id === detailId)!;
                ttTitle.textContent = b.node.label;
                ttCols.innerHTML = b.node.cols.map(c =>
                    `<p class="text-[9px] font-mono ${c.pk?'text-retro-green':c.fk?'text-retro-ledger':'text-retro-slate'}">${c.pk?'● ':c.fk?'↳ ':'  '}${c.name} <span class="opacity-50">${c.type}</span></p>`
                ).join('');
                ttRows.textContent  = b.node.rows;
                ttSync.textContent  = b.node.meta.lastSync;
                ttFresh.textContent = b.node.meta.freshness;
                const feeds = edges.filter(([a]) => a === b.node.id).map(([,c]) => c);
                const from  = edges.filter(([,c]) => c === b.node.id).map(([a]) => a);
                ttFeeds.textContent = feeds.length ? `→ feeds  ${feeds.join(', ')}` : '→ no downstream';
                ttFrom.textContent  = from.length  ? `← from   ${from.join(', ')}`  : '← root input';
                ttPin.style.opacity = (pinnedId === b.node.id) ? '1' : '0';

                // Position: follow cursor when hovering, otherwise pin to the node's screen position
                let tx: number, ty: number;
                if (hoveredId) {
                    tx = Math.min(mouseScreenX + 14, stageW - 240);
                    ty = Math.min(mouseScreenY + 14, stageH - 220);
                } else {
                    const p = b.worldPos.clone().project(camera);
                    const sx = (p.x * 0.5 + 0.5) * stageW;
                    const sy = (-p.y * 0.5 + 0.5) * stageH;
                    tx = Math.min(Math.max(8, sx + 24), stageW - 240);
                    ty = Math.min(Math.max(8, sy + 8), stageH - 220);
                }
                tooltip.style.transform = `translate(${tx}px, ${ty}px)`;
                tooltip.style.opacity = '1';
                schemaCanvas!.style.cursor = hoveredId ? 'pointer' : (isDragging ? 'grabbing' : 'grab');
            } else {
                tooltip.style.opacity = '0';
                schemaCanvas!.style.cursor = isDragging ? 'grabbing' : 'grab';
            }

            renderer.render(scene, camera);
            css3d.render(scene, camera);
            } catch (err) {
                // Never let an exception stop the render loop — log and keep going.
                console.error('[schema tick]', err);
            }
            requestAnimationFrame(tick);
        }
        tick();

        // --- Agent insight cycle ---
        type Insight = {
            tag: string;
            loading: string[];
            path: { table: string; col: string }[];
            edges: [string, string][];
            text: string;
            detail: string;
        };

        const insights: Insight[] = [
            {
                tag: 'Shell Network',
                loading: ['scanning donors…', 'matching shared registered agents…', 'walking ownership chain…'],
                path: [
                    { table: 'donors',          col: 'country' },
                    { table: 'ownership',       col: 'beneficial_owner_id' },
                    { table: 'influence_graph', col: 'strength' },
                ],
                edges: [['donors','companies'], ['companies','ownership'], ['ownership','influence_graph']],
                text: 'Twelve donors share the same registered agent in Jersey.',
                detail: 'Likely common beneficial owner — flagged for review',
            },
            {
                tag: 'Charity Funnel',
                loading: ['joining nonprofits ⨯ donations…', 'tracing trustee ownership…', 'resolving into influence_graph…'],
                path: [
                    { table: 'nonprofits',      col: 'trustees' },
                    { table: 'ownership',       col: 'control_type' },
                    { table: 'influence_graph', col: 'tie_type' },
                ],
                edges: [['nonprofits','ownership'], ['donors','nonprofits'], ['nonprofits','influence_graph']],
                text: 'Think tank\'s top donor is a shell linked to a sitting minister\'s family.',
                detail: '£820k routed via charity · trustees include cabinet relative',
            },
            {
                tag: 'Offshore Trail',
                loading: ['indexing investments.vehicle…', 'walking ownership chain…', 'matching to gov contract…'],
                path: [
                    { table: 'investments',     col: 'vehicle' },
                    { table: 'ownership',       col: 'chain_depth' },
                    { table: 'influence_graph', col: 'strength' },
                ],
                edges: [['investments','ownership'], ['investments','companies'], ['investments','influence_graph']],
                text: '£15m investment via 3-layer offshore vehicle ends at a gov contractor.',
                detail: 'BVI → Jersey → Delaware LLC → bidder on NHS framework',
            },
            {
                tag: 'Undisclosed Donor',
                loading: ['scanning donations.amount clusters…', 'grouping by donor_id…', 'cross-checking register…'],
                path: [
                    { table: 'donations',       col: 'amount' },
                    { table: 'donors',          col: 'flagged' },
                    { table: 'influence_graph', col: 'strength' },
                ],
                edges: [['donations','donors'], ['donations','politicians'], ['donations','influence_graph']],
                text: 'Donor holds a board seat at recipient committee — never disclosed.',
                detail: '£22,400 in donations · board appointment 2023-04',
            },
        ];

        const panel = document.getElementById('agent-panel')!;
        const statusEl = document.getElementById('agent-status')!;
        const loadingEl = document.getElementById('agent-loading')!;
        const loadingText = document.getElementById('agent-loading-text')!;
        const insightEl = document.getElementById('agent-insight')!;
        const insightTag = document.getElementById('agent-insight-tag')!;
        const insightText = document.getElementById('agent-insight-text')!;
        const insightDetail = document.getElementById('agent-insight-detail')!;

        const wait = (ms: number) => new Promise<void>(res => setTimeout(res, ms));

        function litCols(table: string, col: string) {
            return labelLayer!.querySelectorAll<HTMLElement>(`.schema-label[data-table="${table}"] .schema-col[data-col="${col}"]`);
        }

        function clearActive() {
            activeTables.clear();
            activeEdgeKeys.clear();
            labelLayer!.querySelectorAll('.schema-col.is-lit').forEach(el => el.classList.remove('is-lit'));
            clearTraces();
        }

        async function runInsight(ins: Insight) {
            // Always start from a clean slate so an interrupted previous run
            // can't leak lit columns, active edges, or stray trace lines.
            clearActive();
            panel.style.opacity = '1';
            panel.dataset.phase = 'loading';
            insightEl.classList.add('hidden');
            loadingEl.classList.remove('hidden');
            statusEl.textContent = 'scanning';

            try {
                for (let i = 0; i < ins.loading.length; i++) {
                    loadingText.textContent = ins.loading[i];
                    const step = ins.path[i];
                    if (step) {
                        activeTables.add(step.table);
                        litCols(step.table, step.col).forEach(el => el.classList.add('is-lit'));
                        const prev = ins.path[i - 1];
                        if (prev) addTrace(prev.table, prev.col, step.table, step.col);
                    }
                    if (i < ins.edges.length) {
                        const [a, b] = ins.edges[i];
                        activeEdgeKeys.add(`${a}|${b}`);
                    }
                    await wait(900);
                }

                // Phase 2 — reveal
                panel.dataset.phase = 'reveal';
                statusEl.textContent = 'insight';
                loadingEl.classList.add('hidden');
                insightEl.classList.remove('hidden');
                insightTag.textContent = ins.tag;
                insightText.textContent = ins.text;
                insightDetail.textContent = ins.detail;

                await wait(4200);
            } finally {
                // Phase 3 — fade (always runs, even on error)
                panel.style.opacity = '0';
                panel.dataset.phase = 'idle';
                await wait(600);
                clearActive();
            }
        }

        async function cycle() {
            // Brief settle delay before first insight; cycle runs continuously regardless of user input
            await wait(1200);
            let i = 0;
            while (true) {
                try {
                    await runInsight(insights[i % insights.length]);
                } catch (err) {
                    console.error('[agent insight]', err);
                    clearActive();
                    panel.style.opacity = '0';
                }
                i++;
                await wait(600);
            }
        }
        cycle();
    }

    // --- Alternative Hero: Ingest Lens (insight chips revealed by displacement) ---
    const lensStage = document.getElementById('lens-stage') as HTMLElement | null;
    const lensCanvas = document.getElementById('lens-canvas') as HTMLCanvasElement | null;
    if (lensStage && lensCanvas) {
        const lensStats = document.getElementById('lens-stats')!;
        const ctx = lensCanvas.getContext('2d', { alpha: true })!;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);

        const FONT = '12px "IBM Plex Mono", ui-monospace, monospace';
        const FONT_CHIP = '600 14px "Inter", system-ui, sans-serif';
        const FONT_CHIP_SMALL = '600 10px "Inter", system-ui, sans-serif';
        const LINE_HEIGHT = 13;

        function sizeLens() {
            const w = lensStage!.clientWidth, h = lensStage!.clientHeight;
            lensCanvas!.width  = Math.floor(w * dpr);
            lensCanvas!.height = Math.floor(h * dpr);
            lensCanvas!.style.width  = w + 'px';
            lensCanvas!.style.height = h + 'px';
            ctx.setTransform(1, 0, 0, 1, 0, 0);
            ctx.scale(dpr, dpr);
            ctx.textBaseline = 'alphabetic';
        }
        sizeLens();
        window.addEventListener('resize', sizeLens);

        // --- Scrolling raw event lines ---
        type Line = { raw: string; y: number; speed: number; offset: number; rawWidth: number };

        const companies   = ['acme_corp','globex_inc','umbrella_co','vandelay','initech','tyrell','hooli','soylent','massive_dyn','pied_piper','wonka_ltd','dunder_mifflin','wayne_ent'];
        const merchants = ['EC','Lobby Register','Companies House','Contracts Finder','OpenCorporates'];
        const currencies = ['USD','EUR','GBP','CAD','AUD','SGD'];
        const events    = ['donation.filed','lobbying.registered','contract.awarded','board.appointed','disclosure.amended','filing.late','ubo.linked'];
        const txCodes   = ['ec_0007621','orcl_2026Q1_042','ch_09876543','ch_SC287614','cf_CCS-2026-021','ted_2026-OJS84','ec_0014902'];
        const months    = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

        const pick = <T,>(arr: T[]) => arr[Math.floor(Math.random() * arr.length)];
        const pad2 = (n: number) => String(n).padStart(2, '0');

        function makeRaw(): string {
            const vendor   = pick(companies);
            const merchant = pick(merchants);
            const cur      = pick(currencies);
            const amt      = (Math.random() * 9900 + 100).toFixed(2);
            const fee      = (parseFloat(amt) * 0.029 + 0.30).toFixed(2);
            const net      = (parseFloat(amt) - parseFloat(fee)).toFixed(2);
            const code     = pick(txCodes) + '_' + Math.floor(Math.random() * 99999);
            const ev       = pick(events);
            const ts       = Date.now() - Math.floor(Math.random() * 86_400_000);
            const d        = new Date(ts);
            const dateStr  = `${pad2(d.getDate())} ${months[d.getMonth()]} ${pad2(d.getHours())}:${pad2(d.getMinutes())}`;
            switch (Math.floor(Math.random() * 4)) {
                case 0: return `{"e":"${ev}","a":${amt},"c":"${cur}","p":"${merchant.toLowerCase()}","t":${ts},"v":"${vendor}","r":"${code}"}`;
                case 1: return `LOG ${dateStr} src=${merchant.toLowerCase()} sev=info evt=${ev} amt=${amt} fee=${fee} ref=${code} entity=${vendor}`;
                case 2: return `[${ts}|${merchant.toLowerCase()}|${code}|${cur}|${amt}|${fee}|ok|${ev.replace('.','_')}|${vendor}]`;
                default: return `${ev} entity=${vendor} merchant=${merchant.toLowerCase()} amount=${amt} fee=${fee} net=${net} currency=${cur} ref=${code} ts=${ts}`;
            }
        }

        const NUM_LINES = 50;
        const lines: Line[] = [];
        const stageH = lensStage.clientHeight;
        const stageW = lensStage.clientWidth;
        const totalTextH = NUM_LINES * LINE_HEIGHT;
        const yStart = Math.max(0, (stageH - totalTextH) / 2);

        // Measure monospace character width once — Pretext caches natural widths per line for free
        ctx.font = FONT;
        const CHAR_W = ctx.measureText('M').width;

        for (let i = 0; i < NUM_LINES; i++) {
            const raw = makeRaw();
            const prep = prepareWithSegments(raw, FONT);
            lines.push({
                raw,
                y: yStart + (i + 1) * LINE_HEIGHT,
                speed: 22 + Math.random() * 38,
                offset: Math.random() * stageW,
                rawWidth: measureNaturalWidth(prep),
            });
        }

        // --- Fixed insight chips (the answers the agent surfaces) ---
        type Insight = { category: string; label: string; x: number; y: number; w: number };

        // Curated set — fewer chips so they have room to breathe inside the lens
        // and never overlap each other or the lens chrome.
        const INSIGHT_DEFS: Array<{ category: string; label: string }> = [
            { category: 'Donors',     label: 'Hidden donor surfaced' },
            { category: 'Network',    label: 'Influence graph generated' },
            { category: 'Profile',    label: 'Politician profile resolved' },
            { category: 'Conflict',   label: 'Conflict of interest flagged' },
            { category: 'Voting',     label: 'Voting pattern analyzed' },
            { category: 'Filings',    label: 'Disclosure cross-checked' },
            { category: 'Companies',  label: 'Shell network detected' },
            { category: 'Contracts',  label: 'Contract award mapped' },
        ];

        const insights: Insight[] = INSIGHT_DEFS.map(d => ({ ...d, x: 0, y: 0, w: 0 }));

        function placeInsights() {
            const w = lensStage!.clientWidth;
            const h = lensStage!.clientHeight;
            // Each chip gets its own dedicated horizontal band so two chips can never
            // share a row. X position alternates left/right of center to keep the layout
            // visually balanced without any column boundaries that could be crossed.
            const padTop = 70;
            const padBot = 70;
            const usableH = h - padTop - padBot;
            const rowH = usableH / Math.max(1, insights.length);
            const xPattern = [0.30, 0.66, 0.34, 0.64, 0.30, 0.68, 0.34, 0.62];
            ctx.font = FONT_CHIP;
            for (let i = 0; i < insights.length; i++) {
                insights[i].x = w * xPattern[i % xPattern.length];
                insights[i].y = padTop + rowH * (i + 0.5);
                insights[i].w = ctx.measureText(insights[i].label).width + 44;
            }
        }
        placeInsights();
        window.addEventListener('resize', placeInsights);

        // --- Lens state ---
        const lens = {
            x: stageW * 0.5,
            y: stageH * 0.5,
            targetX: stageW * 0.5,
            targetY: stageH * 0.5,
            r: 160,
        };

        lensStage.addEventListener('mousemove', (e) => {
            const r = lensStage.getBoundingClientRect();
            lens.targetX = e.clientX - r.left;
            lens.targetY = e.clientY - r.top;
        });
        lensStage.addEventListener('mouseleave', () => {
            lens.targetX = lensStage!.clientWidth * 0.5;
            lens.targetY = lensStage!.clientHeight * 0.5;
        });

        let lastT = performance.now();
        let revealedCount = 0;
        let statBudget = 0;

        // The lens is drawn in two passes so the insight chips sit BETWEEN the glass tint
        // and the rim/highlights — they read as a second layer revealed by the lens.

        function drawLensBackdrop(cx: number, cy: number, r: number) {
            // Drop shadow (gives the disc physical presence on the paper)
            const shadow = ctx.createRadialGradient(cx + 4, cy + 7, r * 0.6, cx + 4, cy + 7, r * 1.20);
            shadow.addColorStop(0, 'rgba(26, 26, 26, 0.16)');
            shadow.addColorStop(1, 'rgba(26, 26, 26, 0)');
            ctx.fillStyle = shadow;
            ctx.beginPath();
            ctx.arc(cx + 4, cy + 7, r * 1.20, 0, Math.PI * 2);
            ctx.fill();

            // Soft wash inside the lens — mutes the raw text but lets it bleed through
            // enough to see the first layer is still there.
            ctx.fillStyle = 'rgba(255, 255, 255, 0.55)';
            ctx.beginPath();
            ctx.arc(cx, cy, r, 0, Math.PI * 2);
            ctx.fill();

            // Subtle glass tint on top — bright top-left highlight, faint greenish wash on
            // the lower-right. Gives the magnifying-glass character without obscuring chips.
            const glass = ctx.createRadialGradient(cx - r * 0.35, cy - r * 0.4, r * 0.05, cx, cy, r);
            glass.addColorStop(0,   'rgba(255, 255, 255, 0.30)');
            glass.addColorStop(0.6, 'rgba(255, 255, 255, 0.04)');
            glass.addColorStop(1,   'rgba(15, 61, 46, 0.05)');
            ctx.fillStyle = glass;
            ctx.beginPath();
            ctx.arc(cx, cy, r, 0, Math.PI * 2);
            ctx.fill();
        }

        function drawLensRim(cx: number, cy: number, r: number) {
            // Thin inner ring (the inner edge of the glass)
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.45)';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.arc(cx, cy, r - 2.5, 0, Math.PI * 2);
            ctx.stroke();

            // Slim rim — single hairline in deep green
            ctx.strokeStyle = 'rgba(15, 61, 46, 0.85)';
            ctx.lineWidth = 1.25;
            ctx.beginPath();
            ctx.arc(cx, cy, r, 0, Math.PI * 2);
            ctx.stroke();

            // Subtle specular highlight (top-left arc) — just enough to suggest glass
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.55)';
            ctx.lineWidth = 1.25;
            ctx.beginPath();
            ctx.arc(cx, cy, r - 6, -Math.PI * 0.88, -Math.PI * 0.65);
            ctx.stroke();
        }

        function drawInsightChip(ins: Insight) {
            const padH = 18;
            ctx.font = FONT_CHIP;
            const textW = ctx.measureText(ins.label).width;
            const chipW = textW + padH * 2;
            const chipH = 38;
            const x = ins.x - chipW / 2;
            const y = ins.y - chipH / 2;
            const rr = 5;

            // Deep-green pill
            ctx.fillStyle = '#0F3D2E';
            ctx.beginPath();
            ctx.moveTo(x + rr, y);
            ctx.lineTo(x + chipW - rr, y);
            ctx.quadraticCurveTo(x + chipW, y, x + chipW, y + rr);
            ctx.lineTo(x + chipW, y + chipH - rr);
            ctx.quadraticCurveTo(x + chipW, y + chipH, x + chipW - rr, y + chipH);
            ctx.lineTo(x + rr, y + chipH);
            ctx.quadraticCurveTo(x, y + chipH, x, y + chipH - rr);
            ctx.lineTo(x, y + rr);
            ctx.quadraticCurveTo(x, y, x + rr, y);
            ctx.closePath();
            ctx.fill();

            // Check dot — light/white for contrast on green
            ctx.fillStyle = 'rgba(255, 255, 255, 0.9)';
            ctx.beginPath();
            ctx.arc(x + padH * 0.55, y + chipH / 2, 3, 0, Math.PI * 2);
            ctx.fill();

            // Label — white text on deep green
            ctx.fillStyle = '#FFFFFF';
            ctx.font = FONT_CHIP;
            ctx.fillText(ins.label, x + padH + 9, y + chipH / 2 + 5);

            // Caption above (in deep green, on the white lens wash)
            ctx.font = FONT_CHIP_SMALL;
            ctx.fillStyle = 'rgba(15, 61, 46, 0.7)';
            ctx.fillText(ins.category.toUpperCase(), x + 2, y - 8);
        }

        function tick(now: number) {
            try {
                const dt = Math.min(0.05, (now - lastT) / 1000);
                lastT = now;

                const w = lensStage!.clientWidth;
                const h = lensStage!.clientHeight;

                // Smooth lens follow
                lens.x += (lens.targetX - lens.x) * 0.20;
                lens.y += (lens.targetY - lens.y) * 0.20;

                ctx.clearRect(0, 0, w, h);

                // Pass 1: raw scrolling lines — rendered everywhere with no displacement
                ctx.font = FONT;
                ctx.fillStyle = 'rgba(26, 26, 26, 0.50)';
                for (const line of lines) {
                    line.offset -= line.speed * dt;
                    const lapW = line.rawWidth + 80;
                    if (line.offset <= -lapW) line.offset += lapW;
                    let x = line.offset;
                    while (x < w) {
                        ctx.fillText(line.raw, x, line.y);
                        x += lapW;
                    }
                }

                // Pass 2: lens backdrop — shadow + a strong white wash that fades the raw
                // text out inside the disc, so it reads as a frosted second layer underneath.
                drawLensBackdrop(lens.x, lens.y, lens.r);

                // Pass 3: insight chips, CLIPPED to the lens circle so only the portion of
                // each chip actually inside the lens is visible.
                revealedCount = 0;
                ctx.save();
                ctx.beginPath();
                ctx.arc(lens.x, lens.y, lens.r, 0, Math.PI * 2);
                ctx.clip();
                for (const ins of insights) {
                    // Cheap bounding-box reject: if the chip's bbox doesn't overlap the lens
                    // circle's bbox, skip it. Anything that survives gets clipped exactly.
                    const halfW = ins.w / 2, halfH = 18;
                    if (ins.x + halfW < lens.x - lens.r) continue;
                    if (ins.x - halfW > lens.x + lens.r) continue;
                    if (ins.y + halfH < lens.y - lens.r) continue;
                    if (ins.y - halfH > lens.y + lens.r) continue;
                    drawInsightChip(ins);
                    revealedCount++;
                }
                ctx.restore();

                // Pass 4: lens rim, highlights, handle, label
                drawLensRim(lens.x, lens.y, lens.r);

                // Stats every ~400ms
                statBudget += now - lastT;
                if (statBudget > 0) {
                    lensStats.textContent = `${revealedCount} INSIGHTS SURFACED · ${Math.round(1 / Math.max(0.001, dt))} fps`;
                    statBudget = -400;
                }
            } catch (err) {
                console.error('[ingest lens]', err);
            }
            requestAnimationFrame(tick);
        }

        // Wait for fonts so character-width measurement matches what we actually paint
        const start = () => requestAnimationFrame(tick);
        if (document.fonts && document.fonts.ready) {
            document.fonts.ready.then(start);
        } else {
            start();
        }
    }

  </script>

  <style is:global>
    /* CSS3DRenderer creates intermediate wrappers that default to pointer-events: auto.
       Force everything inside the label layer to be transparent to mouse input so drags
       and wheels always reach the canvas underneath, even when cards cover it. */
    #schema-labels,
    #schema-labels * {
      pointer-events: none !important;
    }
    .schema-label {
      width: 188px;
      font-family: "IBM Plex Mono", monospace;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      transition: opacity 0.35s ease;
    }
    .schema-card {
      border: 1px solid rgba(26, 26, 26, 0.18);
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 2px 8px -2px rgba(26, 26, 26, 0.10);
      border-left: 2px solid var(--accent, #0F3D2E);
      transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    }
    .schema-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      padding: 6px 10px;
      background: rgba(26, 26, 26, 0.025);
      border-bottom: 1px solid rgba(26, 26, 26, 0.08);
      font-size: 10px;
      font-weight: 600;
      color: #1A1A1A;
      text-transform: lowercase;
      letter-spacing: 0.01em;
    }
    .schema-card-rows {
      color: #6B7280;
      font-weight: 400;
      font-size: 8px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .schema-card-body {
      padding: 5px 10px 7px;
    }
    .schema-col {
      display: grid;
      grid-template-columns: 18px 1fr auto;
      align-items: center;
      gap: 6px;
      font-size: 8.5px;
      line-height: 1.65;
      color: rgba(26, 26, 26, 0.55);
      padding: 1.5px 0;
    }
    .schema-col-tag {
      font-size: 7px;
      font-weight: 600;
      letter-spacing: 0.04em;
      opacity: 0.55;
    }
    .schema-col-type {
      font-size: 7.5px;
      color: #6B7280;
      opacity: 0.65;
    }
    .schema-col.is-pk {
      color: #0F3D2E;
      font-weight: 600;
    }
    .schema-col.is-pk .schema-col-tag {
      color: #0F3D2E;
      opacity: 1;
    }
    .schema-col.is-fk {
      color: #1A5B43;
    }
    .schema-col.is-fk .schema-col-tag {
      color: #1A5B43;
      opacity: 0.9;
    }
    .schema-col-more {
      font-size: 7.5px;
      color: rgba(26, 26, 26, 0.35);
      padding: 3px 0 1px;
      border-top: 1px dashed rgba(26, 26, 26, 0.10);
      margin-top: 3px;
      letter-spacing: 0.04em;
    }
    /* Extra columns are always hidden inside the card so the box never resizes;
       hover / click reveals them in the rich tooltip instead. */
    .schema-col.is-extra { display: none; }
    .schema-label.is-hovered .schema-card {
      background: #FFFFFF;
      border-color: rgba(15, 61, 46, 0.85);
      box-shadow: 0 6px 18px -6px rgba(15, 61, 46, 0.28);
    }
    .schema-label.is-active .schema-card {
      background: #FFFFFF;
      border-color: rgba(15, 61, 46, 0.85);
      box-shadow: 0 0 0 1px rgba(15, 61, 46, 0.18), 0 6px 18px -6px rgba(15, 61, 46, 0.22);
    }
    .schema-label.is-pinned .schema-card {
      background: #FFFFFF;
      border-color: rgba(15, 61, 46, 0.95);
      box-shadow: 0 0 0 2px rgba(15, 61, 46, 0.22), 0 10px 22px -8px rgba(15, 61, 46, 0.28);
    }
    /* Focal node — slightly more prominent typography */
    .schema-label.is-focal .schema-card-header { font-size: 11px; padding: 7px 11px; }
    .schema-label.is-focal .schema-card { border-left-width: 3px; }
    /* When the agent is running an insight, the dimmed (non-involved) nodes use this hook */
    .schema-label.is-dimmed .schema-card {
      box-shadow: none;
    }
    .schema-col.is-lit {
      background: rgba(15, 61, 46, 0.10);
      color: #0F3D2E !important;
      animation: schema-col-pulse 1.6s ease-in-out infinite;
    }
    .schema-col.is-lit .schema-col-type {
      color: #0F3D2E !important;
      opacity: 0.7;
    }
    .schema-col.is-lit .schema-col-tag {
      color: #0F3D2E !important;
      opacity: 1;
    }
    @keyframes schema-col-pulse {
      0%, 100% { background: rgba(15, 61, 46, 0.10); }
      50%      { background: rgba(15, 61, 46, 0.22); }
    }

    /* Agent panel */
    #agent-panel .agent-dot::after {
      content: "";
      position: absolute;
      inset: -3px;
      border-radius: 9999px;
      border: 1px solid rgba(15, 61, 46, 0.5);
      animation: agent-dot-pulse 1.8s ease-out infinite;
    }
    @keyframes agent-dot-pulse {
      0%   { transform: scale(0.6); opacity: 0.9; }
      100% { transform: scale(2.2); opacity: 0; }
    }
    .agent-loader span {
      width: 4px;
      height: 4px;
      border-radius: 9999px;
      background: #0F3D2E;
      display: inline-block;
      opacity: 0.4;
      animation: agent-loader-bounce 1.1s ease-in-out infinite;
    }
    .agent-loader span:nth-child(2) { animation-delay: 0.15s; }
    .agent-loader span:nth-child(3) { animation-delay: 0.30s; }
    @keyframes agent-loader-bounce {
      0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
      40%           { transform: translateY(-3px); opacity: 1; }
    }
    #agent-panel[data-phase="reveal"] #agent-insight-tag {
      color: #0F3D2E;
    }
    #agent-panel[data-phase="reveal"] .agent-dot {
      background: #0F3D2E;
    }

  </style>
</LightLayout>
