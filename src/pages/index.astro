              cols:[{name:'nonprofit_id',type:'INT',pk:true},{name:'name',type:'VARCHAR'},{name:'type',type:'VARCHAR'},{name:'trustees',type:'INT'},{name:'annual_income',type:'DECIMAL'},{name:'charity_no',type:'VARCHAR'}],
              rows:'168K rows',          meta:{ lastSync:'14 min ago', freshness:'97.2%' } },
