              rows:'12.6K rows',         meta:{ lastSync:'4 min ago',  freshness:'99.8%' } },
            { id:'donations',      label:'donations',      group:'payment',  tier:'middle', x:-1.6, y: 0.3, z: 0.1,
              cols:[{name:'donation_id',type:'BIGINT',pk:true},{name:'politician_id',type:'INT',fk:true},{name:'donor_id',type:'INT',fk:true},{name:'amount',type:'DECIMAL'},{name:'filing_date',type:'DATE'},{name:'source',type:'VARCHAR'}],
              rows:'18.2M rows',         meta:{ lastSync:'2 min ago',  freshness:'99.4%' } },
            { id:'donors',   label:'donors',   group:'core',  tier:'middle', x: 1.7, y: 0.3, z: 0.1,
              cols:[{name:'donor_id',type:'BIGINT',pk:true},{name:'name',type:'VARCHAR'},{name:'type',type:'VARCHAR'},{name:'country',type:'CHAR(2)'},{name:'lifetime_given',type:'DECIMAL'},{name:'flagged',type:'BOOLEAN'}],
              rows:'2.4M rows',          meta:{ lastSync:'live · 12s', freshness:'99.9%' } },

