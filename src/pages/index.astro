---
export const prerender = true;
import LightLayout from '../layouts/LightLayout.astro';
---

<LightLayout title="Lattice — Mapping Power, Money, and Influence">
    
    <!-- Background Elements -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden bg-retro-bg retro-grid">
        <!-- Interactive 3D Wireframe Globe -->
        <canvas id="bg-globe-canvas" class="absolute right-[-20%] top-[-10%] w-[1200px] h-[1200px] opacity-40"></canvas>
        
        <!-- Global Data Network Overlay (from image) -->
        <div class="absolute inset-0 max-w-[1600px] mx-auto px-8 py-16 hidden lg:block opacity-60">
            <!-- Header -->
            <div class="absolute top-12 left-1/2 -translate-x-1/2 flex gap-32 text-[9px] font-mono text-retro-slate tracking-widest uppercase">
                <div>
                    <p class="text-retro-ink font-semibold">INFLUENCE NETWORK</p>
                    <p>ENTITY MAP 004.23</p>
                </div>
                <div class="flex gap-8">
                    <div class="flex flex-col items-center"><span class="text-retro-ink">ENTITIES</span><span>1.2M</span></div>
                    <div class="flex flex-col items-center"><span class="text-retro-ink">TIES</span><span>4.7M</span></div>
                    <div class="flex flex-col items-center"><span class="text-retro-ink">SOURCES</span><span>312</span></div>
                </div>
            </div>



            <div class="absolute bottom-12 left-8 text-[8px] font-mono text-retro-slate tracking-widest space-y-2 uppercase">
                <div class="flex items-center gap-2">
                    <div class="w-1.5 h-1.5 bg-retro-green rounded-sm"></div>
                    <span>ENTITY</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-4 border-t border-dashed border-retro-green/50"></div>
                    <span>RELATIONSHIP</span>
                </div>
            </div>
        </div>

        <div class="absolute inset-0 opacity-10 mix-blend-multiply pointer-events-none">
            <video src="/retro/Névtelen (1280 x 1280 képpont).mp4" autoplay muted loop playsinline class="w-full h-full object-cover grayscale"></video>
        </div>
        <div class="absolute inset-0 opacity-20 mix-blend-multiply pointer-events-none">
            <img src="/retro/ChatGPT Image May 14, 2026, 09_38_00 PM (3).png" class="w-full h-full object-cover grayscale" alt="Blueprint Background" />
        </div>
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at center, transparent 0%, var(--color-retro-bg) 95%);"></div>
    </div>

    <!-- Navigation -->
    <nav class="relative z-50 px-8 py-6 flex items-center justify-between border-b border-retro-border bg-retro-bg/80 backdrop-blur-md">
        <a href="/" class="flex items-center gap-3 text-retro-ink">
            <svg width="30" height="30" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="miter" aria-hidden="true">
                <g transform="rotate(45 50 50)">
                    <rect x="20" y="20" width="60" height="60"/>
                    <line x1="32" y1="20" x2="32" y2="80"/>
                    <line x1="44" y1="20" x2="44" y2="80"/>
                    <line x1="56" y1="20" x2="56" y2="80"/>
                    <line x1="68" y1="20" x2="68" y2="80"/>
                    <line x1="20" y1="32" x2="80" y2="32"/>
                    <line x1="20" y1="44" x2="80" y2="44"/>
                    <line x1="20" y1="56" x2="80" y2="56"/>
                    <line x1="20" y1="68" x2="80" y2="68"/>
                </g>
            </svg>
            <span class="font-serif text-2xl tracking-tight">Lattice</span>
        </a>
        <div class="hidden md:flex items-center gap-10 font-medium text-sm text-retro-slate">
            <a href="/bills" class="hover:text-retro-ink transition-colors">Policy Translator</a>
            <a href="/expose" class="hover:text-retro-ink transition-colors">Exposé</a>
            <a href="#pricing-section" class="hover:text-retro-ink transition-colors">Pricing</a>
            <a href="#" class="hover:text-retro-ink transition-colors">About</a>
        </div>
        <button class="bg-retro-green text-white px-6 py-2.5 text-sm font-medium hover:bg-retro-ledger transition-colors rounded-sm shadow-[3px_3px_0px_rgba(15,61,46,1)] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px]">
            Request Access
        </button>
    </nav>


    <main class="relative z-10 max-w-[1600px] mx-auto">
        
        <!-- SECTION 1: HERO -->
        <section class="min-h-[90vh] flex flex-col justify-center px-8 py-20 relative overflow-hidden">
            <div class="max-w-7xl mx-auto w-full relative z-10">
                <div class="lg:w-3/4 xl:w-2/3 animate-fade-up">
                    <h1 class="text-5xl md:text-6xl lg:text-[5.5rem] leading-[1.02] font-semibold text-retro-ink tracking-tight mb-12">
                        We uncover the hidden networks in the elite <span class="text-retro-green italic font-light">and make policy accessible.</span>
                    </h1>

                    <div class="flex flex-wrap gap-4 mb-24">
                        <a href="/bills" class="inline-block bg-retro-green text-white px-10 py-4 text-sm font-medium hover:bg-retro-ledger transition-colors rounded-sm shadow-[4px_4px_0px_rgba(15,61,46,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px]">
                            Open Policy Translator →
                        </a>
                        <a href="/expose" class="inline-block border border-retro-ink/20 bg-white text-retro-ink px-10 py-4 text-sm font-medium hover:border-retro-green hover:text-retro-green transition-colors rounded-sm">
                            Open Exposé →
                        </a>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 pt-12 border-t border-retro-border">
                        <div>
                            <p class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2">ENTITIES TRACKED</p>
                            <p class="text-3xl font-medium text-retro-ink mb-1">1.2M+</p>
                            <p class="text-[11px] font-mono text-retro-slate">Politicians, firms, donors</p>
                        </div>
                        <div>
                            <p class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2">DISCLOSURES PARSED</p>
                            <p class="text-3xl font-medium text-retro-ink mb-1">4.7M+</p>
                            <p class="text-[11px] font-mono text-retro-slate">Filings & records</p>
                        </div>
                        <div>
                            <p class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2">SOURCE COVERAGE</p>
                            <p class="text-3xl font-medium text-retro-ink mb-1">312</p>
                            <p class="text-[11px] font-mono text-retro-slate">Public registries</p>
                        </div>
                        <div>
                            <p class="text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-2">UPDATE LATENCY</p>
                            <p class="text-3xl font-medium text-retro-ink mb-1">&lt; 24 hrs</p>
                            <p class="text-[11px] font-mono text-retro-slate">From filing to graph</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 1.5: ALTERNATIVE HERO — INGEST LENS -->
        <section class="relative bg-retro-bg py-24 px-8 overflow-hidden border-t border-retro-border" id="ingest-hero">
            <!-- Architectural grid backdrop -->
            <div class="absolute inset-0 pointer-events-none opacity-[0.05]" style="background-image: linear-gradient(to right, #1A1A1A 1px, transparent 1px), linear-gradient(to bottom, #1A1A1A 1px, transparent 1px); background-size: 64px 64px;"></div>

            <!-- Two-column layout: lens on the left, headline + copy on the right -->
            <div class="max-w-7xl mx-auto relative grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

                <!-- Left: lens animation stage -->
                <div class="lg:col-span-7">
                    <div id="lens-stage" class="relative h-[640px] rounded-sm overflow-hidden border border-retro-ink/15 cursor-none" style="background: linear-gradient(180deg, #FBFCEE 0%, #F4F5DC 100%);">
                        <canvas id="lens-canvas" class="absolute inset-0 w-full h-full"></canvas>
                        <div class="absolute top-3 left-3 text-[9px] font-mono text-retro-ink/40 pointer-events-none flex items-center gap-2">
                            <span class="inline-block w-1.5 h-1.5 rounded-full bg-retro-green animate-pulse"></span>
                            <span>LIVE FEEDS · 50 SOURCES</span>
                        </div>
                        <div class="absolute top-3 right-3 text-[9px] font-mono text-retro-ink/40 pointer-events-none">
                            <p id="lens-stats">— TIES SURFACED</p>
                        </div>
                        <div class="absolute bottom-3 left-3 text-[9px] font-mono text-retro-ink/40 pointer-events-none">
                            <p>MOVE THE LENS · RECORDS → CONNECTIONS</p>
                        </div>
                        <div class="absolute bottom-3 right-3 text-[9px] font-mono text-retro-ink/40 pointer-events-none">
                            <p>EVERY EDGE CITED</p>
                        </div>
                    </div>
                </div>

                <!-- Right: headline + copy -->
                <div class="lg:col-span-5">
                    <span class="inline-block px-3 py-1 border border-retro-ink/15 bg-white rounded-sm text-[10px] font-mono text-retro-green uppercase tracking-widest mb-6">v2 · Source-backed graph</span>
                    <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold text-retro-ink tracking-tight leading-[1.05] mb-6">
                        Power leaves a paper trail. <span class="italic font-light text-retro-green">Most of it is just hard to read.</span>
                    </h2>
                    <p class="text-base text-retro-slate leading-relaxed max-w-md">Lattice ingests filings, donations, lobbying disclosures, and corporate registries, then maps the relationships between politicians, companies, and money so journalists, researchers, and citizens can follow them.</p>
                </div>
            </div>
        </section>

        <!-- SECTION 2: THE PROBLEM -->
        <section class="py-32 px-8 border-y border-retro-border bg-white relative overflow-hidden">
            <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(rgba(0,0,0,1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,1) 1px, transparent 1px); background-size: 40px 40px;"></div>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 relative z-10">
                <div class="reveal">
                    <span class="inline-block px-3 py-1 border border-retro-border bg-retro-bg rounded-sm text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-8">The problem</span>
                    <h2 class="text-4xl md:text-5xl lg:text-[4rem] font-semibold leading-tight mb-8 text-retro-ink tracking-tight">
                        Basic accountability questions take months to answer.
                    </h2>
                    <p class="text-xl text-retro-slate leading-relaxed font-light">
                        The blocker isn't curiosity — it's the work of pulling filings from dozens of registries, reconciling spellings, and linking entities across jurisdictions. Reporters and researchers already know what to ask.
                    </p>
                </div>
                <div class="flex flex-col justify-center">
                    <ul class="space-y-0 divide-y divide-retro-border border-t border-b border-retro-border">
                        <li class="gsap-problem-item py-8 text-2xl md:text-3xl font-light cursor-default flex gap-6 px-4 -mx-4 hover:bg-retro-bg transition-colors">
                            <span class="text-retro-green font-mono text-lg mt-1 opacity-70">01</span>
                            <span class="text-retro-ink">Who funded this politician — and what do they own?</span>
                        </li>
                        <li class="gsap-problem-item py-8 text-2xl md:text-3xl font-light cursor-default flex gap-6 px-4 -mx-4 hover:bg-retro-bg transition-colors">
                            <span class="text-retro-green font-mono text-lg mt-1 opacity-70">02</span>
                            <span class="text-retro-ink">Which firms are lobbying on this bill, and who hired them?</span>
                        </li>
                        <li class="gsap-problem-item py-8 text-2xl md:text-3xl font-light cursor-default flex gap-6 px-4 -mx-4 hover:bg-retro-bg transition-colors">
                            <span class="text-retro-green font-mono text-lg mt-1 opacity-70">03</span>
                            <span class="text-retro-ink">Who actually benefits from this contract award?</span>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- SECTION 3: HOW IT WORKS (PINNED SCROLL GALLERY) -->
        <section id="how-it-works-section" class="relative bg-retro-bg">
            <div class="px-8 py-24 border-b border-retro-border relative z-20 bg-retro-bg">
                <span class="inline-block px-3 py-1 border border-retro-border bg-white rounded-sm text-[10px] font-mono text-retro-slate uppercase tracking-widest mb-6">How it works</span>
                <h2 class="text-5xl md:text-6xl font-semibold mb-6 text-retro-ink tracking-tight">A research desk that never sleeps.</h2>
            </div>

            <!-- The Pinned Container -->
            <div id="pin-container" class="flex flex-col lg:flex-row h-screen border-b border-retro-border overflow-hidden">
                
                <!-- Left: Text Steps -->
                <div class="w-full lg:w-1/2 p-12 lg:p-24 flex flex-col justify-center relative bg-white border-r border-retro-border">
                    <div id="step-1" class="absolute inset-0 p-12 lg:p-24 flex flex-col justify-center opacity-100 bg-white z-30">
                        <div class="text-retro-green font-mono text-2xl mb-6 border border-retro-green/30 bg-retro-green/5 w-12 h-12 flex items-center justify-center rounded-sm">01</div>
                        <h3 class="text-3xl font-semibold mb-6 text-retro-ink">Ingest filings from every public source.</h3>
                        <p class="text-xl text-retro-slate leading-relaxed">Campaign finance, lobbying disclosures, corporate registries, court dockets, and procurement records become one queryable layer.</p>
                    </div>

                    <div id="step-2" class="absolute inset-0 p-12 lg:p-24 flex flex-col justify-center opacity-0 bg-white z-20 translate-y-12">
                        <div class="text-retro-green font-mono text-2xl mb-6 border border-retro-green/30 bg-retro-green/5 w-12 h-12 flex items-center justify-center rounded-sm">02</div>
                        <h3 class="text-3xl font-semibold mb-6 text-retro-ink">Resolve entities across jurisdictions.</h3>
                        <p class="text-xl text-retro-slate leading-relaxed mb-12">"John A. Smith" the donor, "J. Smith" on the board, and "Smith Holdings LLC" the contractor collapse into one identity — with the source filings cited.</p>
                    </div>

                    <div id="step-3" class="absolute inset-0 p-12 lg:p-24 flex flex-col justify-center opacity-0 bg-white z-10 translate-y-12">
                        <div class="text-retro-green font-mono text-2xl mb-6 border border-retro-green/30 bg-retro-green/5 w-12 h-12 flex items-center justify-center rounded-sm">03</div>
                        <h3 class="text-3xl font-semibold mb-6 text-retro-ink">Trace the relationships behind a decision.</h3>
                        <p class="text-xl text-retro-slate leading-relaxed mb-12">Follow donations, ownership, board seats, and lobbying ties across politicians, firms, and intermediaries — every edge backed by a primary source.</p>
                    </div>
                </div>

                <!-- Right: Animated Agent UI (Primary Focus) -->
                <div class="w-full lg:w-1/2 relative bg-retro-bg overflow-hidden h-[50vh] lg:h-full flex items-center justify-center">

                    <!-- Single shared background video — plays continuously across all three steps -->
                    <div class="absolute inset-0 opacity-25 mix-blend-luminosity grayscale pointer-events-none scale-110 z-0">
                        <video src="/retro/Névtelen terv (5).mp4" autoplay muted loop playsinline class="w-full h-full object-cover"></video>
                    </div>

                    <!-- UI 1: Contract Parsing -->
                    <div id="ui-1" class="absolute inset-0 p-8 lg:p-16 flex items-center justify-center opacity-100 z-10">
                        <div class="w-full max-w-md bg-white border border-retro-border rounded-md shadow-lg p-8 relative z-20" id="contract-parsing-card">
                            <h4 class="font-semibold text-retro-ink text-sm mb-8 border-b border-retro-border pb-4 flex justify-between items-center">
                                <span>Filing parser</span>
                                <span class="gsap-parsing-status text-[9px] font-mono bg-retro-bg border border-retro-border px-2 py-0.5 rounded-sm text-retro-slate">AWAITING_DOC</span>
                            </h4>
                            <div class="flex gap-8">
                                <div class="w-32 bg-retro-bg border border-retro-border rounded flex flex-col p-3 h-40 relative overflow-hidden shadow-inner">
                                    <div class="gsap-scan-laser absolute top-0 left-0 right-0 h-[3px] bg-retro-green shadow-[0_0_12px_rgba(34,197,94,0.8)] z-10" style="top:-3px;"></div>
                                    <div class="text-[9px] font-mono text-retro-slate mb-4">Consultant Lobbyist<br/>Register Q1.pdf</div>
                                    <div class="space-y-2">
                                        <div class="w-full h-1 bg-retro-slate/20 rounded"></div>
                                        <div class="w-3/4 h-1 bg-retro-slate/20 rounded"></div>
                                        <div class="gsap-doc-line-1 w-5/6 h-1 bg-retro-slate/20 rounded relative overflow-hidden">
                                            <div class="gsap-doc-highlight-1 absolute inset-0 bg-retro-green -translate-x-full"></div>
                                        </div>
                                        <div class="w-full h-1 bg-retro-slate/20 rounded mt-2"></div>
                                        <div class="gsap-doc-line-2 w-4/5 h-1 bg-retro-slate/20 rounded relative overflow-hidden">
                                            <div class="gsap-doc-highlight-2 absolute inset-0 bg-retro-green -translate-x-full"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex-1 space-y-4">
                                    <p class="text-[10px] font-mono text-retro-slate border-b border-retro-border pb-2">Extracted ties</p>
                                    <div class="gsap-extracted-term-1 opacity-0 flex justify-between text-sm">
                                        <span class="text-retro-ink font-medium">Client</span>
                                        <span class="font-mono text-retro-green bg-retro-green/10 px-1.5 py-0.5 rounded">Acme Corp</span>
                                    </div>
                                    <div class="gsap-extracted-term-2 opacity-0 flex justify-between text-sm">
                                        <span class="text-retro-ink font-medium">Spend Q3</span>
                                        <span class="font-mono text-retro-green bg-retro-green/10 px-1.5 py-0.5 rounded">£1.1M</span>
                                    </div>
                                    <div class="flex justify-between text-xs mt-6 pt-3 border-t border-retro-border">
                                        <span class="text-retro-slate font-mono">Confidence</span>
                                        <span class="gsap-confidence-score text-retro-slate font-mono font-bold">--%</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>



                    <!-- UI 2: Data Lineage Map -->
                    <div id="ui-2" class="absolute inset-0 p-8 lg:p-16 flex items-center justify-center opacity-0 translate-y-12">
                        <div class="w-full max-w-lg bg-white border border-retro-border rounded-md shadow-lg p-8 relative z-20">
                            <h4 class="font-semibold text-retro-ink text-sm mb-8 border-b border-retro-border pb-4">Entity resolution map</h4>
                            <div class="flex justify-between items-center relative py-8">
                                <div class="absolute left-[120px] right-[120px] top-1/2 -translate-y-1/2 h-[1px] border-t border-dashed border-retro-slate/40 z-0"></div>
                                <div class="flex flex-col gap-4 z-10 w-[140px]">
                                    <div class="bg-white border border-retro-border p-3 rounded shadow-sm">
                                        <p class="text-xs font-semibold text-retro-ink">Electoral Commission</p>
                                        <p class="text-[8px] font-mono text-retro-slate mt-1">3.1M records</p>
                                    </div>
                                    <div class="bg-white border border-retro-border p-3 rounded shadow-sm">
                                        <p class="text-xs font-semibold text-retro-ink">OpenCorporates</p>
                                        <p class="text-[8px] font-mono text-retro-slate mt-1">Live sync</p>
                                    </div>
                                </div>
                                <div class="z-10 bg-white border-2 border-retro-green rounded-md p-6 shadow-xl w-[180px] text-center transform scale-110">
                                    <span class="font-bold tracking-tight text-retro-ink text-sm mb-3 block">lattice engine</span>
                                    <div class="space-y-2 text-left">
                                        <p class="text-[9px] font-mono text-retro-ink flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full border border-retro-green"></span> Entity resolution</p>
                                        <p class="text-[9px] font-mono text-retro-ink flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-retro-green"></span> Edge inference</p>
                                    </div>
                                </div>
                                <div class="flex flex-col gap-4 z-10 w-[140px]">
                                    <div class="bg-white border border-retro-border p-3 rounded shadow-sm">
                                        <p class="text-xs font-semibold text-retro-ink">Influence graph</p>
                                        <p class="text-[8px] font-mono text-retro-ledger mt-1">4.7M edges resolved</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- UI 3: Answer Metrics -->
                    <div id="ui-3" class="absolute inset-0 p-8 lg:p-16 flex items-center justify-center opacity-0 translate-y-12">
                        <div class="w-full max-w-lg bg-white border border-retro-border rounded-md shadow-lg p-8 relative z-20">
                            <h4 class="font-semibold text-retro-ink text-sm mb-8 border-b border-retro-border pb-4">Investigation output: Influence brief</h4>
                            <div class="grid grid-cols-2 gap-6">
                                <div class="border border-retro-border rounded-sm p-6 hover:border-retro-green transition-all bg-retro-bg group">
                                    <p class="text-xs font-mono text-retro-slate uppercase tracking-widest mb-3">Donor exposure</p>
                                    <p class="text-4xl font-semibold text-retro-ink mb-1">£3.4M</p>
                                    <p class="text-[10px] font-mono text-retro-ledger">to bill sponsors</p>
                                </div>
                                <div class="border border-retro-border rounded-sm p-6 hover:border-retro-green transition-all bg-retro-bg group">
                                    <p class="text-xs font-mono text-retro-slate uppercase tracking-widest mb-3">Hidden ties</p>
                                    <p class="text-4xl font-semibold text-retro-ink mb-1">17</p>
                                    <p class="text-[10px] font-mono text-retro-green">undisclosed in filings</p>
                                </div>
                                <div class="col-span-2 border border-retro-border rounded-sm p-6 bg-retro-ink text-white">
                                    <div class="flex justify-between items-center mb-4">
                                        <p class="text-xs font-mono tracking-widest text-retro-green">LEAD WORTH REPORTING</p>
                                        <span class="text-[10px] font-mono opacity-50">#442-RE</span>
                                    </div>
                                    <p class="text-sm font-light leading-relaxed">"Three MPs sponsoring the Economic Crime Bill received £880k from donors linked to the same parent group that hired their largest registered lobbyist last quarter."</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    

                </div>
            </div>
            <!-- Scroll space for the pinned section -->
            <div id="scroll-space" class="h-[200vh]"></div>
        </section>



        <!-- SECTION 3.5: INTERACTIVE DATA SCHEMA -->
        <section class="py-24 px-8 bg-retro-bg overflow-hidden relative" id="schema-section">
            <div class="absolute inset-0 pointer-events-none opacity-[0.05]" style="background-image: linear-gradient(to right, #1A1A1A 1px, transparent 1px), linear-gradient(to bottom, #1A1A1A 1px, transparent 1px); background-size: 56px 56px;"></div>
            <div class="max-w-7xl mx-auto relative">
                <div class="flex flex-col lg:flex-row gap-16 items-center">
                    <!-- Left: Copy -->
                    <div class="lg:w-2/5 reveal">
                        <span class="inline-block px-3 py-1 border border-retro-ink/15 bg-white rounded-sm text-[10px] font-mono text-retro-green uppercase tracking-widest mb-6">The Graph</span>
