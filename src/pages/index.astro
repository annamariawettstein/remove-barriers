              cols:[{name:'company_id',type:'INT',pk:true},{name:'name',type:'VARCHAR'},{name:'jurisdiction',type:'CHAR(2)'},{name:'sic_code',type:'VARCHAR'},{name:'parent_id',type:'INT',fk:true}],
              rows:'1.4M rows',          meta:{ lastSync:'1 h ago',    freshness:'98.6%' } },
            { id:'investments',     label:'investments',     group:'payment',  tier:'outer',  x: 3.0, y: 1.5, z:-0.9,
              cols:[{name:'investment_id',type:'INT',pk:true},{name:'holder_id',type:'INT',fk:true},{name:'holding_id',type:'INT',fk:true},{name:'shares_pct',type:'DECIMAL'},{name:'value',type:'DECIMAL'},{name:'vehicle',type:'VARCHAR'}],
              rows:'420K rows',         meta:{ lastSync:'24 min ago', freshness:'95.1%' } },
            { id:'ownership',     label:'ownership',     group:'contract', tier:'outer',  x: 3.1, y:-0.5, z:-0.7,
              cols:[{name:'ownership_id',type:'INT',pk:true},{name:'entity_id',type:'INT',fk:true},{name:'beneficial_owner_id',type:'INT',fk:true},{name:'control_type',type:'VARCHAR'},{name:'percentage',type:'DECIMAL'},{name:'chain_depth',type:'TINYINT'}],
