---
export const prerender = true;
import LightLayout from '../layouts/LightLayout.astro';
---

<LightLayout title="Data Weaver — Redirecting to Expose">
  <main class="relative z-10 max-w-[780px] mx-auto px-6 lg:px-8 py-20 bg-retro-bg">
    <meta http-equiv="refresh" content="0; url=/expose" />
    <script is:inline>
      window.location.replace('/expose');
    </script>

    <div class="border border-retro-border rounded-md bg-white p-8 shadow-[4px_4px_0px_rgba(230,230,230,1)]">
      <div class="text-[10px] font-mono text-retro-green uppercase tracking-[0.22em] mb-3">Redirecting</div>
      <h1 class="text-3xl font-semibold text-retro-ink tracking-tight mb-3">Data Weaver is now called Expose.</h1>
      <p class="text-base text-retro-slate leading-relaxed mb-6">
        The extension and chatbot chooser still exists, but the product name is back to Expose.
      </p>
      <a href="/expose" class="inline-block bg-retro-green text-white px-6 py-3 text-sm font-medium hover:bg-retro-ledger transition-colors rounded-sm shadow-[3px_3px_0px_rgba(15,61,46,1)] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px]">
        Go to Expose →
      </a>
    </div>
  </main>
</LightLayout>
