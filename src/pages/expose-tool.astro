---
export const prerender = false;
import LightLayout from '../layouts/LightLayout.astro';
import ExposeResearchApp from '../components/expose/ExposeResearchApp';
import { getCaseStudyPreset } from '../data/exposeCaseStudies';

const initialName = Astro.url.searchParams.get('name')?.trim() || '';
const initialData = initialName ? getCaseStudyPreset(initialName) : null;
---

<LightLayout title="Expose — 3D investigator">
  <ExposeResearchApp initialName={initialName} initialData={initialData} client:load />
</LightLayout>
